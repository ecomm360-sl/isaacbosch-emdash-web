---
export const prerender = false;

import Base from "../layouts/Base.astro";
import ClientCard from "../components/ClientCard.astro";
import { clients, getSectorsWithCounts } from "../data/clients";
import { buildItemListSchema } from "../lib/seo";

const sectors = getSectorsWithCounts();
const totalClients = clients.length;

// Sort clients alphabetically by name for stable display
const sortedClients = [...clients].sort((a, b) =>
	a.name.localeCompare(b.name, "es"),
);

const clientsListSchema = buildItemListSchema({
	name: "Clientes",
	description: "Marcas con las que Isaac Bosch ha trabajado",
	items: sortedClients.slice(0, 30).map((c) => ({
		name: c.name,
		url: c.url ?? "/clientes",
	})),
});
---

<Base
	title="Clientes"
	description="Mas de 15 anos trabajando con marcas como Damm, Cofidis, Cetelem, Caixa, RACC, Vichy Catalan, Cirsa, Intersport, Brownie, PD Paola, Hoffmann, Kibuc, Madden y muchas mas. Consultoria eCommerce B2B, integracion ERP y transformacion digital."
	ogType="page"
	ogSlug="clientes"
	jsonLd={clientsListSchema}
>
	<section class="clients-page">
		<header class="page-header">
			<span class="page-eyebrow">Clientes</span>
			<h1 class="page-title">He trabajado con marcas como estas</h1>
			<p class="page-subtitle">
				Mas de 15 anos acompanando a empresas industriales, fabricantes, distribuidores, retailers y servicios en su transformacion digital, integracion ERP y estrategia eCommerce B2B.
			</p>
			<div class="stats-strip">
				<div class="stat">
					<span class="stat-value">{totalClients}+</span>
					<span class="stat-label">marcas atendidas</span>
				</div>
				<div class="stat">
					<span class="stat-value">{sectors.length}</span>
					<span class="stat-label">sectores</span>
				</div>
				<div class="stat">
					<span class="stat-value">2009</span>
					<span class="stat-label">desde</span>
				</div>
			</div>
		</header>

		<nav class="sector-filter" aria-label="Filtrar por sector">
			<button type="button" class="filter-chip is-active" data-filter="all">
				Todos <span class="filter-count">{totalClients}</span>
			</button>
			{sectors.map((s) => (
				<button type="button" class="filter-chip" data-filter={s.sector}>
					{s.label} <span class="filter-count">{s.count}</span>
				</button>
			))}
		</nav>

		<div class="clients-grid" id="clients-grid">
			{sortedClients.map((client) => <ClientCard client={client} />)}
		</div>

		<aside class="clients-cta">
			<div class="cta-inner">
				<h2 class="cta-title">Tu marca podria estar aqui?</h2>
				<p class="cta-text">
					Si tu empresa necesita digitalizar su canal B2B, integrar un ERP con un eCommerce, o aplicar IA a procesos comerciales, hablemos.
				</p>
				<a href="/contacto" class="cta-btn">Hablamos de tu proyecto</a>
			</div>
		</aside>
	</section>
</Base>

<script>
	const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
	const cards = document.querySelectorAll<HTMLElement>(".client-card");

	function applyFilter(filter: string) {
		cards.forEach((card) => {
			const matches = filter === "all" || card.dataset.sector === filter;
			if (matches) {
				card.style.display = "";
				card.style.opacity = "1";
			} else {
				card.style.display = "none";
			}
		});
	}

	chips.forEach((chip) => {
		chip.addEventListener("click", () => {
			chips.forEach((c) => c.classList.remove("is-active"));
			chip.classList.add("is-active");
			const filter = chip.dataset.filter || "all";
			applyFilter(filter);
		});
	});
</script>

<style>
	.clients-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 820px;
		margin-bottom: var(--spacing-12);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-10);
	}

	.stats-strip {
		display: flex;
		gap: var(--spacing-12);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.stat-value {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: var(--color-accent);
		line-height: 1;
	}

	.stat-label {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.sector-filter {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border);
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		padding: var(--spacing-2) var(--spacing-4);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text-secondary);
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: 9999px;
		cursor: pointer;
		transition: all var(--transition-fast);
	}

	.filter-chip:hover {
		color: var(--color-text);
		border-color: var(--color-text);
	}

	.filter-chip.is-active {
		color: var(--color-on-accent);
		background: var(--color-accent);
		border-color: var(--color-accent);
	}

	.filter-count {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		opacity: 0.7;
	}

	.clients-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-16);
	}

	.clients-cta {
		max-width: 640px;
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-8);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-align: center;
	}

	.cta-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.cta-text {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-6);
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-text);
		color: var(--color-bg);
		border-radius: 9999px;
		font-weight: 500;
		text-decoration: none;
		transition: background var(--transition-fast);
	}

	.cta-btn:hover {
		background: var(--color-accent);
	}

	@media (max-width: 1024px) {
		.clients-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (max-width: 640px) {
		.clients-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}

		.stats-strip {
			gap: var(--spacing-8);
			flex-wrap: wrap;
		}

		.clients-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--spacing-2);
		}

		.sector-filter {
			overflow-x: auto;
			flex-wrap: nowrap;
			padding-bottom: var(--spacing-4);
			-webkit-overflow-scrolling: touch;
		}

		.filter-chip {
			flex-shrink: 0;
		}
	}
</style>
