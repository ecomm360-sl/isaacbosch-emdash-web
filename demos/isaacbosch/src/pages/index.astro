---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import AuthorityStrip from "../components/AuthorityStrip.astro";
import EcosystemBand from "../components/EcosystemBand.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	limit: 3,
});

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});
---

<Base
	title="Consultor eCommerce B2B y Fractional CIO en Barcelona"
	description="Convierto empresas industriales en negocios digitales que venden solos. Consultor eCommerce B2B, Fractional CIO y fundador de eComm360, Integrafy y Approsearch."
	ogType="page"
	ogSlug="home"
>
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-byline">
				<img
					src="/isaac-portrait.jpg"
					alt="Retrato ilustrado de Isaac Bosch"
					width="88"
					height="88"
					loading="eager"
					decoding="async"
					class="hero-portrait"
				/>
				<div class="hero-byline-text">
					<span class="hero-byline-name">Isaac Bosch</span>
					<span class="hero-eyebrow">eCommerce B2B &middot; Integración ERP &middot; IA aplicada</span>
				</div>
			</div>
			<h1 class="hero-title">
				Transformación digital industrial para <em>vender</em> y operar mejor.
			</h1>
			<p class="hero-tagline">
				Consultor en eCommerce B2B, integración ERP y arquitectura digital. Empresario desde los 20 años.
			</p>
			<div class="hero-ctas">
				<a href="/servicios/consultoria-ecommerce-b2b" class="btn btn-primary">
					Necesito consultoría B2B
				</a>
				<a href="/fractional-cio" class="btn btn-secondary">
					Busco un Fractional CIO
				</a>
			</div>
			<p class="hero-tagline-brand">
				<em>Del dato al pedido. Sin fricciones.</em>
			</p>
		</div>
	</section>

	<AuthorityStrip />

	<section class="problems">
		<div class="problems-inner">
			<header class="section-header">
				<span class="section-eyebrow">Problemas que resuelvo</span>
				<h2 class="section-title">Lo que probablemente te está frustrando</h2>
				<p class="section-lead">
					Cinco patrones que veo repetirse en empresas industriales y distribuidoras. Si te suena alguno, podemos hablar.
				</p>
			</header>
			<ol class="problems-list">
				<li class="problem">
					<a href="/servicios/consultoria-ecommerce-b2b" class="problem-link">
						<span class="problem-num">01</span>
						<div class="problem-body">
							<h3 class="problem-title">Tu equipo procesa pedidos B2B a mano</h3>
							<p class="problem-text">
								Cada pedido pasa por un comercial que lo introduce manualmente en el ERP. Errores, duplicaciones, días de retraso. Lo que debería ser automático es tu cuello de botella diario.
							</p>
							<span class="problem-cta">Consultoría eCommerce B2B &rarr;</span>
						</div>
					</a>
				</li>
				<li class="problem">
					<a href="/servicios/integracion-erp-ecommerce" class="problem-link">
						<span class="problem-num">02</span>
						<div class="problem-body">
							<h3 class="problem-title">Tu ERP y tu tienda online viven en mundos paralelos</h3>
							<p class="problem-text">
								Los precios se actualizan en SAP pero la web no se entera. El stock cambia en el almacén pero el cliente sigue viendo el dato de ayer. Reconciliación manual cada noche, sobreventa cada semana.
							</p>
							<span class="problem-cta">Integración ERP - eCommerce &rarr;</span>
						</div>
					</a>
				</li>
				<li class="problem">
					<a href="/servicios/consultor-agentes-ia-automatizaciones" class="problem-link">
						<span class="problem-num">03</span>
						<div class="problem-body">
							<h3 class="problem-title">Tu equipo pierde horas en tareas que la IA ya resuelve</h3>
							<p class="problem-text">
								Catalogación de productos, atención a consultas repetitivas, generación de ofertas, seguimiento de pedidos. Procesos donde el criterio humano casi nunca aporta valor real. La IA aplicada al B2B ya está lista para hacerlos.
							</p>
							<span class="problem-cta">Agentes IA y automatizaciones &rarr;</span>
						</div>
					</a>
				</li>
				<li class="problem">
					<a href="/fractional-cio" class="problem-link">
						<span class="problem-num">04</span>
						<div class="problem-body">
							<h3 class="problem-title">No tienes criterio C-level para decidir tu hoja de ruta tecnológica</h3>
							<p class="problem-text">
								Tienes responsable IT operativo pero falta dirección estratégica. No te puedes permitir un CIO full-time, pero pierdes oportunidades, dinero y tiempo por no tener uno. Necesitas un perfil senior part-time, no otro proveedor.
							</p>
							<span class="problem-cta">Fractional CIO &rarr;</span>
						</div>
					</a>
				</li>
				<li class="problem">
					<a href="/servicios/formacion-empresarial-digitalizacion" class="problem-link">
						<span class="problem-num">05</span>
						<div class="problem-body">
							<h3 class="problem-title">Tu equipo necesita formarse pero los cursos genéricos no sirven</h3>
							<p class="problem-text">
								Has probado bonificaciones, masterclasses gratuitas, suscripciones a plataformas. Nada se queda. Lo que tu equipo necesita es contenido aplicado a tu sector, tu stack y tus problemas reales.
							</p>
							<span class="problem-cta">Formación empresarial digital &rarr;</span>
						</div>
					</a>
				</li>
			</ol>
		</div>
	</section>

	<section class="principles">
		<div class="principles-inner">
			<header class="section-header">
				<span class="section-eyebrow">Principios</span>
				<h2 class="section-title">Cómo pienso, cómo trabajo</h2>
			</header>
			<div class="principles-grid">
				<div class="principle">
					<span class="principle-num">01</span>
					<h3 class="principle-title">Claridad</h3>
					<p class="principle-text">Si no se puede explicar en una servilleta, es demasiado complicado.</p>
				</div>
				<div class="principle">
					<span class="principle-num">02</span>
					<h3 class="principle-title">Escalabilidad</h3>
					<p class="principle-text">Diseño a largo plazo. Las decisiones de hoy no deben hipotecar el crecimiento de mañana.</p>
				</div>
				<div class="principle">
					<span class="principle-num">03</span>
					<h3 class="principle-title">Pragmatismo</h3>
					<p class="principle-text">La tecnología solo aporta valor cuando simplifica la realidad.</p>
				</div>
				<div class="principle">
					<span class="principle-num">04</span>
					<h3 class="principle-title">Responsabilidad</h3>
					<p class="principle-text">Construyo sistemas que no dependen de personas clave. Tu equipo se queda con el control, no con la dependencia.</p>
				</div>
			</div>
		</div>
	</section>

	{sortedPosts.length > 0 && (
		<section class="blog-section">
			<div class="section-inner">
				<header class="section-header">
					<span class="section-eyebrow">Blog</span>
					<h2 class="section-title">Notas y reflexiones</h2>
					<a href="/blog" class="section-link">Ver todos los artículos &rarr;</a>
				</header>
				<div class="posts-grid">
					{sortedPosts.map((post) => <PostCard post={post} />)}
				</div>
			</div>
		</section>
	)}

	<EcosystemBand />

	<section class="cta-section">
		<div class="cta-inner">
			<span class="cta-eyebrow">Hablamos</span>
			<h2 class="cta-title">Pide un diagnóstico de 45 minutos</h2>
			<p class="cta-text">
				Cuéntame tu situación. Sin compromiso. Si encajamos, hablamos del proyecto. Si no, te oriento sobre el siguiente paso aunque sea con otro consultor.
			</p>
			<a href="/contacto" class="btn btn-primary">Solicitar diagnóstico</a>
		</div>
	</section>
</Base>

<style>
	/* === Hero === */
	.hero {
		padding: var(--spacing-32) var(--spacing-6) var(--spacing-20);
	}

	.hero-inner {
		max-width: 880px;
		margin: 0 auto;
	}

	.hero-byline {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-8);
	}

	.hero-portrait {
		width: 72px;
		height: 72px;
		object-fit: cover;
		object-position: center 18%;
		border-radius: 50%;
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		flex-shrink: 0;
		transition: transform var(--transition-base);
	}

	.hero-byline:hover .hero-portrait {
		transform: scale(1.04) rotate(-2deg);
	}

	.hero-byline-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.hero-byline-name {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		font-weight: 500;
		color: var(--color-text);
		letter-spacing: var(--tracking-snug);
	}

	.hero-eyebrow {
		display: inline-block;
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-muted);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
		font-weight: 400;
		letter-spacing: var(--tracking-tighter);
		line-height: 1.05;
		color: var(--color-text);
		margin: 0 0 var(--spacing-8);
	}

	.hero-title em {
		font-style: italic;
		color: var(--color-accent);
		font-weight: 400;
	}

	.hero-tagline {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-10);
		max-width: 36em;
	}

	.hero-ctas {
		display: flex;
		gap: var(--spacing-3);
		flex-wrap: wrap;
		margin-bottom: var(--spacing-12);
	}

	.hero-tagline-brand {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		margin: 0;
	}

	.hero-tagline-brand em {
		font-style: italic;
	}

	/* === Buttons === */
	.btn {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-3) var(--spacing-6);
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		text-decoration: none;
		transition: all var(--transition-fast);
		font-family: var(--font-sans);
	}

	.btn-primary {
		background: var(--color-text);
		color: var(--color-bg);
		border: 1px solid var(--color-text);
	}

	.btn-primary:hover {
		background: var(--color-accent);
		color: var(--color-on-accent);
		border-color: var(--color-accent);
	}

	.btn-secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		background: var(--color-surface);
		border-color: var(--color-text);
	}

	/* === Problems === */
	.problems {
		padding: var(--spacing-24) var(--spacing-6);
		background: var(--color-bg);
	}

	.problems-inner {
		max-width: 920px;
		margin: 0 auto;
	}

	.section-lead {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: var(--spacing-4) 0 0;
		max-width: 720px;
	}

	.problems-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--color-border);
	}

	.problem {
		border-bottom: 1px solid var(--color-border);
	}

	.problem-link {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--spacing-8);
		padding: var(--spacing-10) var(--spacing-2);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-base);
	}

	.problem-link:hover {
		background: var(--color-bg-warm);
	}

	.problem-num {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		padding-top: var(--spacing-2);
	}

	.problem-body {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		min-width: 0;
	}

	.problem-title {
		font-family: var(--font-serif);
		font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
		transition: color var(--transition-fast);
	}

	.problem-link:hover .problem-title {
		color: var(--color-accent);
	}

	.problem-text {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		max-width: 60ch;
	}

	.problem-cta {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		margin-top: var(--spacing-2);
	}

	.section-header {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-12);
		max-width: 720px;
	}

	.section-eyebrow {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0;
	}

	.section-link {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		margin-top: var(--spacing-1);
		transition: color var(--transition-fast);
	}

	.section-link:hover {
		color: var(--color-accent);
	}

	/* === Principles === */
	.principles {
		padding: var(--spacing-24) var(--spacing-6);
		background: var(--color-bg);
		border-top: 1px solid var(--color-border);
	}

	.principles-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.principles-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-8);
	}

	.principle {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.principle-num {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
	}

	.principle-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.1;
		color: var(--color-text);
		margin: 0;
	}

	.principle-text {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* === Blog === */
	.blog-section {
		padding: var(--spacing-24) var(--spacing-6);
		background: var(--color-bg-warm);
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-10) var(--spacing-8);
	}

	/* === CTA === */
	.cta-section {
		padding: var(--spacing-24) var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.cta-inner {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
	}

	.cta-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.cta-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.cta-text {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-8);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.principles-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-10);
		}
	}

	@media (max-width: 640px) {
		.hero {
			padding: var(--spacing-20) var(--spacing-5) var(--spacing-16);
		}

		.hero-portrait {
			width: 60px;
			height: 60px;
		}

		.problems,
		.principles,
		.blog-section,
		.cta-section {
			padding: var(--spacing-16) var(--spacing-5);
		}

		.posts-grid,
		.principles-grid {
			grid-template-columns: 1fr;
		}

		.problem-link {
			grid-template-columns: 1fr;
			gap: var(--spacing-3);
			padding: var(--spacing-8) var(--spacing-1);
		}

		.problem-num {
			padding-top: 0;
		}
	}
</style>
