---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PressCard from "../components/PressCard.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	limit: 6,
});
const { entries: services } = await getEmDashCollection("services");
const { entries: press } = await getEmDashCollection("press");

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});
---

<Base
	title="Consultor eCommerce B2B e IA en Barcelona"
	description="Digitalizo y automatizo procesos integrando ERP, IA y Agentes Autonomos. Consultor eCommerce B2B en Barcelona."
>
	<section class="hero">
		<div class="hero-inner">
			<span class="hero-eyebrow">Barcelona &middot; Consultor independiente</span>
			<h1 class="hero-title">
				Digitalizo y automatizo procesos B2B con <em>IA y agentes autonomos</em>.
			</h1>
			<p class="hero-tagline">
				Ayudo a fabricantes, distribuidores y empresas industriales a integrar su ERP con canales de venta online y automatizar operaciones con inteligencia artificial.
			</p>
			<div class="hero-ctas">
				<a href="/servicios" class="btn btn-primary">Ver servicios</a>
				<a href="/contacto" class="btn btn-secondary">Hablamos?</a>
			</div>
		</div>
	</section>

	{sortedPosts.length > 0 && (
		<section class="section section-bordered">
			<div class="section-inner">
				<header class="section-header">
					<span class="section-eyebrow">Blog</span>
					<h2 class="section-title">Notas y reflexiones</h2>
					<a href="/blog" class="section-link">Ver todos los articulos &rarr;</a>
				</header>
				<div class="posts-grid">
					{sortedPosts.map((post) => <PostCard post={post} />)}
				</div>
			</div>
		</section>
	)}

	{services.length > 0 && (
		<section class="section section-warm">
			<div class="section-inner">
				<header class="section-header">
					<span class="section-eyebrow">Servicios</span>
					<h2 class="section-title">Como puedo ayudarte</h2>
					<a href="/servicios" class="section-link">Ver todos los servicios &rarr;</a>
				</header>
				<div class="services-grid">
					{services.map((service) => <ServiceCard service={service} />)}
				</div>
			</div>
		</section>
	)}

	{press.length > 0 && (
		<section class="section">
			<div class="section-inner">
				<header class="section-header">
					<span class="section-eyebrow">Prensa</span>
					<h2 class="section-title">Apariciones en medios</h2>
					<a href="/prensa" class="section-link">Ver todas &rarr;</a>
				</header>
				<div class="press-grid">
					{press.map((item) => <PressCard item={item} />)}
				</div>
			</div>
		</section>
	)}

	<section class="section cta-section">
		<div class="cta-inner">
			<h2 class="cta-title">Tienes un proyecto en mente?</h2>
			<p class="cta-text">
				Trabajo con empresas que quieren digitalizar sus procesos comerciales sin perder el control. Si crees que puedo ayudarte, hablemos.
			</p>
			<a href="/contacto" class="btn btn-primary">Contactar</a>
		</div>
	</section>
</Base>

<style>
	/* === Hero === */
	.hero {
		padding: var(--spacing-32) var(--spacing-6) var(--spacing-24);
	}

	.hero-inner {
		max-width: 820px;
		margin: 0 auto;
	}

	.hero-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-muted);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-6);
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
		font-weight: 400;
		letter-spacing: var(--tracking-tighter);
		line-height: 1.05;
		color: var(--color-text);
		margin: 0 0 var(--spacing-8);
	}

	.hero-title em {
		font-style: italic;
		color: var(--color-accent);
		font-weight: 400;
	}

	.hero-tagline {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-10);
		max-width: 36em;
	}

	.hero-ctas {
		display: flex;
		gap: var(--spacing-3);
		flex-wrap: wrap;
	}

	/* === Buttons === */
	.btn {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-3) var(--spacing-6);
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		text-decoration: none;
		transition: all var(--transition-fast);
		font-family: var(--font-sans);
	}

	.btn-primary {
		background: var(--color-text);
		color: var(--color-bg);
		border: 1px solid var(--color-text);
	}

	.btn-primary:hover {
		background: var(--color-accent);
		color: var(--color-on-accent);
		border-color: var(--color-accent);
	}

	.btn-secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		background: var(--color-surface);
		border-color: var(--color-text);
	}

	/* === Sections === */
	.section {
		padding: var(--spacing-24) var(--spacing-6);
	}

	.section-bordered {
		border-top: 1px solid var(--color-border);
	}

	.section-warm {
		background: var(--color-bg-warm);
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-12);
	}

	.section-eyebrow {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}

	.section-link {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		margin-top: var(--spacing-1);
		transition: color var(--transition-fast);
	}

	.section-link:hover {
		color: var(--color-accent);
	}

	/* === Grids === */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-10) var(--spacing-8);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	.press-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	/* === CTA === */
	.cta-section {
		border-top: 1px solid var(--color-border);
	}

	.cta-inner {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
	}

	.cta-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.cta-text {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-8);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.hero {
			padding: var(--spacing-20) var(--spacing-5) var(--spacing-16);
		}

		.section {
			padding: var(--spacing-16) var(--spacing-5);
		}

		.posts-grid,
		.services-grid,
		.press-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
