---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PressCard from "../components/PressCard.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	limit: 6,
});
const { entries: services, cacheHint: servicesCacheHint } =
	await getEmDashCollection("services");
const { entries: press, cacheHint: pressCacheHint } =
	await getEmDashCollection("press");

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});
---

<Base
	title="Consultor eCommerce B2B e IA en Barcelona"
	description="Digitalizo y automatizo procesos integrando ERP, IA y Agentes Autonomos. Consultor eCommerce B2B en Barcelona."
>
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-title">Isaac Bosch</h1>
			<p class="hero-tagline">
				Digitalizo y automatizo procesos integrando ERP, IA y Agentes
				Autonomos
			</p>
			<div class="hero-ctas">
				<a href="/servicios" class="btn btn-primary">Ver servicios</a>
				<a href="/blog" class="btn btn-secondary">Leer el blog</a>
			</div>
		</div>
	</section>

	{
		sortedPosts.length > 0 && (
			<section class="section">
				<div class="section-inner">
					<header class="section-header">
						<h2 class="section-title">
							<a href="/blog">Ultimos articulos</a>
						</h2>
					</header>
					<div class="posts-grid">
						{sortedPosts.map((post) => (
							<PostCard post={post} />
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		services.length > 0 && (
			<section class="section">
				<div class="section-inner">
					<header class="section-header">
						<h2 class="section-title">
							<a href="/servicios">Servicios</a>
						</h2>
					</header>
					<div class="services-grid">
						{services.map((service) => (
							<ServiceCard service={service} />
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		press.length > 0 && (
			<section class="section">
				<div class="section-inner">
					<header class="section-header">
						<h2 class="section-title">
							<a href="/prensa">En prensa</a>
						</h2>
					</header>
					<div class="press-grid">
						{press.map((item) => (
							<PressCard item={item} />
						))}
					</div>
				</div>
			</section>
		)
	}
</Base>

<style>
	/* Hero */
	.hero {
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
		text-align: center;
	}

	.hero-inner {
		max-width: var(--content-width);
		margin: 0 auto;
	}

	.hero-title {
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 var(--spacing-4) 0;
	}

	.hero-tagline {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-8) 0;
		max-width: 36em;
		margin-inline: auto;
	}

	.hero-ctas {
		display: flex;
		justify-content: center;
		gap: var(--spacing-3);
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-6);
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-on-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
	}

	.btn-secondary {
		background: var(--color-surface);
		color: var(--color-text);
	}

	.btn-secondary:hover {
		background: var(--color-border);
	}

	/* Sections */
	.section {
		padding: var(--spacing-20) var(--spacing-6);
	}

	.section + .section {
		padding-top: 0;
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.section-header {
		margin-bottom: var(--spacing-8);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.section-title {
		font-size: var(--font-size-sm);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin: 0;
	}

	.section-title a {
		color: inherit;
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.section-title a:hover {
		color: var(--color-accent);
	}

	/* Grids */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-4);
	}

	.press-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-4);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-8) var(--spacing-6);
		}
	}

	@media (max-width: 600px) {
		.hero {
			padding: var(--spacing-16) var(--spacing-4) var(--spacing-12);
		}

		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.services-grid,
		.press-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
