---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ServiceCard from "../../components/ServiceCard.astro";

const { entries: services, cacheHint } = await getEmDashCollection("services", {
	orderBy: { order: "asc" },
});

Astro.cache.set(cacheHint);

const sortedServices = services.toSorted((a, b) => {
	const orderA = a.data.order ?? 99;
	const orderB = b.data.order ?? 99;
	return orderA - orderB;
});
---

<Base
	title="Servicios"
	description="Consultoria eCommerce B2B, agentes de IA, integracion ERP y formacion empresarial en digitalizacion. Servicios para empresas industriales que necesitan transformar su canal digital."
>
	<section class="services-page">
		<header class="page-header">
			<span class="page-eyebrow">Servicios</span>
			<h1 class="page-title">Como puedo ayudarte</h1>
			<p class="page-subtitle">
				Cuatro especialidades complementarias para empresas industriales y distribuidoras que estan transformando su canal de venta digital. Trabajo en proyectos cerrados, consultoria por horas y direccion tecnologica part-time.
			</p>
		</header>

		{sortedServices.length === 0 ? (
			<p class="empty-message">Proximamente.</p>
		) : (
			<div class="services-grid">
				{sortedServices.map((service) => <ServiceCard service={service} />)}
			</div>
		)}

		<aside class="services-cta">
			<p>
				<strong>Necesitas direccion tecnologica continua?</strong> Tambien ofrezco
				<a href="/fractional-cio">Fractional CIO</a> para empresas que requieren un perfil C-level part-time.
			</p>
		</aside>
	</section>
</Base>

<style>
	.services-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	.empty-message {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.services-cta {
		margin-top: var(--spacing-16);
		padding: var(--spacing-6) var(--spacing-8);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.services-cta p {
		margin: 0;
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.services-cta a {
		color: var(--color-accent);
	}

	@media (max-width: 640px) {
		.services-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
