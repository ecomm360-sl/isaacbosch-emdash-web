---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ServiceCard from "../../components/ServiceCard.astro";

const { entries: services, cacheHint } = await getEmDashCollection("services", {
	orderBy: { order: "asc" },
});

Astro.cache.set(cacheHint);
---

<Base
	title="Servicios"
	description="Como puedo ayudarte: consultoria eCommerce B2B, automatizacion e integracion con IA"
>
	<section class="services-page">
		<header class="page-header">
			<h1 class="page-title">Servicios</h1>
			<p class="page-subtitle">Como puedo ayudarte</p>
		</header>

		<div class="services-grid">
			{services.map((service) => <ServiceCard service={service} />)}
		</div>
	</section>
</Base>

<style>
	.services-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin: 0 0 var(--spacing-3) 0;
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-4);
	}

	@media (max-width: 600px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
