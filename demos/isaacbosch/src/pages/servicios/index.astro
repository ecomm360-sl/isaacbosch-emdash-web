---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import { buildItemListSchema } from "../../lib/seo";

const { entries: services, cacheHint } = await getEmDashCollection("services", {
	orderBy: { order: "asc" },
});

Astro.cache.set(cacheHint);

const sortedServices = services.toSorted((a, b) => {
	const orderA = a.data.order ?? 99;
	const orderB = b.data.order ?? 99;
	return orderA - orderB;
});

// Fractional CIO is rendered separately because it has its own
// standalone landing at /fractional-cio/ instead of /servicios/X
const fractionalCioCard = {
	id: "fractional-cio",
	data: {
		title: "Fractional CIO para pymes industriales",
		summary:
			"Dirección tecnológica part-time para empresas industriales de 20-200 personas que necesitan criterio C-level sin asumir el coste de un CIO full-time.",
		icon: "user",
		order: 5,
	},
};

const serviceListItems = [
	...sortedServices.map((s) => ({
		name: s.data.title,
		url: `/servicios/${s.id}`,
		description: s.data.summary ?? undefined,
	})),
	{
		name: fractionalCioCard.data.title,
		url: "/fractional-cio",
		description: fractionalCioCard.data.summary,
	},
];

const itemListSchema = buildItemListSchema({
	name: "Servicios de Isaac Bosch",
	description:
		"Consultoría eCommerce B2B, agentes de IA, integración ERP, formación y dirección tecnológica part-time.",
	items: serviceListItems,
});
---

<Base
	title="Servicios"
	description="Consultoría eCommerce B2B, agentes de IA, integración ERP y formación empresarial en digitalización. Servicios para empresas industriales que necesitan transformar su canal digital."
	ogType="page"
	ogSlug="servicios"
	jsonLd={itemListSchema}
>
	<section class="services-page">
		<header class="page-header">
			<span class="page-eyebrow">Servicios</span>
			<h1 class="page-title">Cómo puedo ayudarte</h1>
			<p class="page-subtitle">
				Cinco especialidades complementarias para empresas industriales y distribuidoras que están transformando su canal de venta digital. Trabajo en proyectos cerrados, consultoría por horas y dirección tecnológica part-time.
			</p>
		</header>

		<div class="services-grid">
			{sortedServices.map((service) => <ServiceCard service={service} />)}
			<ServiceCard service={fractionalCioCard} href="/fractional-cio" />
		</div>
	</section>
</Base>

<style>
	.services-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	@media (max-width: 640px) {
		.services-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
