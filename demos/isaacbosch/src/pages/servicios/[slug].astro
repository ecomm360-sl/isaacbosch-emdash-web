---
export const prerender = false;

import { getEmDashEntry, getSeoMeta } from "emdash";
import Base from "../../layouts/Base.astro";
import SiteBlocks from "../../components/SiteBlocks.astro";

const { slug } = Astro.params;
const result = await getEmDashEntry("services", slug!);
if (!result) return Astro.redirect("/404");

const { entry: service, cacheHint } = result;
Astro.cache.set(cacheHint);

const seo = getSeoMeta(service);
---

<Base
	title={seo.title || service.data.title}
	description={seo.description || service.data.summary}
	image={seo.ogImage}
	robots={seo.robots}
	canonical={seo.canonical}
	type="website"
	content={{ collection: "services", id: service.data.id, slug: service.id }}
>
	<article class="service-detail">
		<header class="service-header">
			{service.data.icon && <span class="service-icon">{service.data.icon}</span>}
			<h1 class="service-title">{service.data.title}</h1>
			{
				service.data.summary && (
					<p class="service-summary">{service.data.summary}</p>
				)
			}
		</header>

		{service.data.content && <SiteBlocks value={service.data.content} />}
	</article>
</Base>

<style>
	.service-detail {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.service-header {
		margin-bottom: var(--spacing-12);
	}

	.service-icon {
		display: block;
		font-size: var(--font-size-3xl);
		margin-bottom: var(--spacing-4);
	}

	.service-title {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin: 0 0 var(--spacing-4) 0;
	}

	.service-summary {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: 0;
	}
</style>
