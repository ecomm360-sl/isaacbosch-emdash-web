---
export const prerender = false;

import { getEmDashEntry, getSeoMeta } from "emdash";
import Base from "../../layouts/Base.astro";
import SiteBlocks from "../../components/SiteBlocks.astro";

const { slug } = Astro.params;

const result = await getEmDashEntry("services", slug!);

if (!result || !result.entry) {
	return Astro.redirect("/404");
}

const { entry, cacheHint } = result;
Astro.cache.set(cacheHint);

const seo = getSeoMeta(entry);
---

<Base
	title={seo.title ?? entry.data.title}
	description={seo.description ?? entry.data.summary}
	image={seo.ogImage}
	content={{ collection: "services", id: entry.data.id, slug: entry.id }}
>
	<article class="page-content">
		<header class="page-header">
			<a href="/servicios" class="back-link">&larr; Servicios</a>
			<span class="page-eyebrow">Servicio</span>
			<h1 class="page-title">{entry.data.title}</h1>
			{entry.data.summary && <p class="page-subtitle">{entry.data.summary}</p>}
		</header>
		{entry.data.content && (
			<div class="prose">
				<SiteBlocks value={entry.data.content} />
			</div>
		)}
	</article>
</Base>

<style>
	.page-content {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.back-link {
		display: inline-block;
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		margin-bottom: var(--spacing-8);
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (max-width: 640px) {
		.page-content {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}
	}
</style>
