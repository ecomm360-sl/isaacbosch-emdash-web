---
export const prerender = false;

const collection = Astro.url.searchParams.get("collection") || "posts";
const id = Astro.url.searchParams.get("id") || "";

const log: Array<unknown> = [];

// @ts-ignore
const user = Astro.locals.user;
log.push({ step: "user", value: user || "NOT LOGGED IN" });

// @ts-ignore
const emdash = Astro.locals.emdash;
log.push({ step: "emdash present?", value: !!emdash });

if (id && emdash) {
	try {
		const got = await emdash.handleContentGet(collection, id);
		log.push({ step: "handleContentGet", value: got });
	} catch (e) {
		log.push({ step: "handleContentGet THREW", value: String(e) });
	}

	try {
		const pub = await emdash.handleContentPublish(collection, id);
		log.push({ step: "handleContentPublish", value: pub });
	} catch (e) {
		log.push({ step: "handleContentPublish THREW", value: String(e) });
	}
}

const dump = JSON.stringify(log, null, 2);
---

<html>
<body style="font-family: monospace; padding: 24px;">
	<h1>Debug publish</h1>
	<p>?collection=posts&id=&lt;slug&gt;</p>
	<pre style="white-space: pre-wrap; word-break: break-all;">{dump}</pre>
</body>
</html>
