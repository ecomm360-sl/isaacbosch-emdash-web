---
export const prerender = false;

const user = (Astro.locals as { user?: unknown }).user;
const userJson = JSON.stringify(user, null, 2);
---

<!doctype html>
<html>
<head><meta charset="utf-8"><title>Debug me</title></head>
<body style="font-family: monospace; padding: 24px; background: #faf9f5;">
	<h1>Debug: who am I?</h1>
	<p>This is what the server sees in <code>Astro.locals.user</code>:</p>
	<pre style="background: white; padding: 16px; border: 1px solid #ddd; border-radius: 4px; overflow-x: auto;">{userJson}</pre>
	<p style="color: #666; font-size: 12px;">If <code>role</code> is not 50, that's why publish/delete fails.</p>
</body>
</html>
