---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PressCard from "../components/PressCard.astro";

const { entries: press, cacheHint } = await getEmDashCollection("press");
Astro.cache.set(cacheHint);
---

<Base
	title="Prensa"
	description="Apariciones en prensa y medios de comunicacion."
>
	<section class="press-page">
		<header class="page-header">
			<h1 class="page-title">Prensa</h1>
			<p class="page-subtitle">Apariciones en medios y publicaciones</p>
		</header>

		{
			press.length > 0 ? (
				<div class="press-grid">
					{press.map((item) => (
						<PressCard item={item} />
					))}
				</div>
			) : (
				<p class="empty">No hay apariciones en prensa todavia.</p>
			)
		}
	</section>
</Base>

<style>
	.press-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
	}

	.page-title {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 var(--spacing-2) 0;
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.press-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-4);
	}

	.empty {
		color: var(--color-muted);
		text-align: center;
		padding: var(--spacing-12) 0;
	}

	@media (max-width: 600px) {
		.press-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
