---
export const prerender = false;

const headers: Record<string, string> = {};
for (const [k, v] of Astro.request.headers.entries()) {
	headers[k] = v;
}

const info = {
	"astro_url_origin": Astro.url.origin,
	"astro_url_host": Astro.url.host,
	"astro_url_protocol": Astro.url.protocol,
	"astro_request_url": Astro.request.url,
	"headers": headers,
};

const dump = JSON.stringify(info, null, 2);
---
<html>
<body style="font-family: monospace; padding: 24px; font-size: 12px;">
	<h1>Debug headers</h1>
	<pre style="white-space: pre-wrap; word-break: break-all;">{dump}</pre>
</body>
</html>
