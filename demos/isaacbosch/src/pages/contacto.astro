---
export const prerender = false;

import { getEmDashEntry, getSeoMeta } from "emdash";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { buildContactPageSchema, type BreadcrumbItem } from "../lib/seo";

const { entry, cacheHint } = await getEmDashEntry("pages", "contacto");
Astro.cache.set(cacheHint);

if (!entry) {
	return Astro.redirect("/404");
}

const seo = getSeoMeta(entry);

const PHONE_DISPLAY = "+34 655 588 668";
const PHONE_TEL = "+34655588668";
const WHATSAPP_URL =
	"https://wa.me/34655588668?text=Hola%20Isaac%2C%20me%20gustar%C3%ADa%20hablar%20contigo";
const LINKEDIN_URL = "https://linkedin.com/in/isaacbosch";
const EMAIL = "mail@isaacbosch.com";

const breadcrumbs: BreadcrumbItem[] = [
	{ name: "Inicio", url: "/" },
	{ name: "Contacto", url: "/contacto" },
];

const contactSchema = buildContactPageSchema();
---

<Base
	title={seo.title ?? "Contacto"}
	description={seo.description ?? "Contacta con Isaac Bosch para hablar de tu proyecto. Consultoría eCommerce B2B y Fractional CIO."}
	image={seo.ogImage}
	content={{ collection: "pages", id: entry.data.id, slug: entry.id }}
	ogType="page"
	ogSlug="contacto"
	breadcrumbs={breadcrumbs}
	jsonLd={contactSchema}
>
	<section class="contact-page">
		<header class="page-header">
			<Breadcrumbs items={breadcrumbs} />
			<span class="page-eyebrow">Contacto</span>
			<h1 class="page-title">Hablamos</h1>
			<p class="page-subtitle">
				Cuéntame tu situación. Si encajamos, hablamos del proyecto. Si no, te oriento sobre el siguiente paso aunque sea con otro consultor.
			</p>
		</header>

		<div class="contact-grid">
			<aside class="contact-info">
				<header class="info-header">
					<span class="info-eyebrow">Cómo contactar</span>
					<h2 class="info-title">Elige el canal que prefieras</h2>
				</header>

				<ul class="contact-channels">
					<li>
						<a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="channel">
							<span class="channel-icon" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
							</span>
							<span class="channel-body">
								<span class="channel-label">WhatsApp</span>
								<span class="channel-value">Respuesta rápida en horario laboral</span>
							</span>
							<span class="channel-arrow" aria-hidden="true">&rarr;</span>
						</a>
					</li>
					<li>
						<a href={`tel:${PHONE_TEL}`} class="channel">
							<span class="channel-icon" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
							</span>
							<span class="channel-body">
								<span class="channel-label">Llamar</span>
								<span class="channel-value">{PHONE_DISPLAY}</span>
							</span>
							<span class="channel-arrow" aria-hidden="true">&rarr;</span>
						</a>
					</li>
					<li>
						<a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="channel">
							<span class="channel-icon" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
							</span>
							<span class="channel-body">
								<span class="channel-label">LinkedIn</span>
								<span class="channel-value">/in/isaacbosch</span>
							</span>
							<span class="channel-arrow" aria-hidden="true">&rarr;</span>
						</a>
					</li>
					<li>
						<a href={`mailto:${EMAIL}`} class="channel">
							<span class="channel-icon" aria-hidden="true">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
							</span>
							<span class="channel-body">
								<span class="channel-label">Email</span>
								<span class="channel-value">{EMAIL}</span>
							</span>
							<span class="channel-arrow" aria-hidden="true">&rarr;</span>
						</a>
					</li>
				</ul>

				<div class="info-meta">
					<div class="meta-item">
						<span class="meta-label">Ubicación</span>
						<span class="meta-value">Pla. Urquinaona, 6, 14B<br/>08010 Barcelona, España</span>
					</div>
					<div class="meta-item">
						<span class="meta-label">Disponibilidad</span>
						<span class="meta-value">Proyectos remotos globales y presenciales en Barcelona</span>
					</div>
					<div class="meta-item">
						<span class="meta-label">Tiempo de respuesta</span>
						<span class="meta-value">Menos de 24h en días laborales</span>
					</div>
				</div>
			</aside>

			<section class="contact-form-wrap">
				<header class="form-header">
					<span class="form-eyebrow">Formulario</span>
					<h2 class="form-title">O cuéntame por aquí</h2>
					<p class="form-subtitle">
						Te respondo en menos de 24 horas en días laborales. Cuanto más concreto seas, mejor te puedo orientar.
					</p>
				</header>

				<form id="contact-form" class="contact-form" novalidate>
					<div class="form-row form-row-double">
						<div class="form-field">
							<label for="cf-name">Nombre <span class="required">*</span></label>
							<input
								type="text"
								id="cf-name"
								name="name"
								required
								autocomplete="name"
								minlength="2"
								maxlength="100"
							/>
						</div>
						<div class="form-field">
							<label for="cf-email">Email <span class="required">*</span></label>
							<input
								type="email"
								id="cf-email"
								name="email"
								required
								autocomplete="email"
								maxlength="200"
							/>
						</div>
					</div>

					<div class="form-row form-row-double">
						<div class="form-field">
							<label for="cf-company">Empresa</label>
							<input
								type="text"
								id="cf-company"
								name="company"
								autocomplete="organization"
								maxlength="120"
							/>
						</div>
						<div class="form-field">
							<label for="cf-subject">Tipo de consulta</label>
							<select id="cf-subject" name="subject">
								<option value="otro">Otra consulta</option>
								<option value="consultoria-b2b">Consultoría eCommerce B2B</option>
								<option value="fractional-cio">Fractional CIO</option>
							</select>
						</div>
					</div>

					<div class="form-field">
						<label for="cf-message">Mensaje <span class="required">*</span></label>
						<textarea
							id="cf-message"
							name="message"
							required
							rows="6"
							minlength="10"
							maxlength="4000"
							placeholder="Cuéntame tu situación: qué empresa eres, qué necesitas, en qué punto estás..."></textarea>
					</div>

					<!-- Honeypot — hidden from real users -->
					<div class="hp-field" aria-hidden="true">
						<label for="cf-website">Website (no rellenar)</label>
						<input type="text" id="cf-website" name="website" tabindex="-1" autocomplete="off" />
					</div>

					<p class="form-privacy">
						Al enviar aceptas que use tus datos para responder a tu consulta. Más info en la <a href="/politica-privacidad">política de privacidad</a>.
					</p>

					<div class="form-footer">
						<button type="submit" class="submit-btn">
							<span class="btn-label">Enviar mensaje</span>
							<span class="btn-loading" aria-hidden="true">Enviando...</span>
						</button>
					</div>

					<div class="form-feedback form-feedback-success" role="status" hidden>
						<strong>Mensaje enviado.</strong> Te responderé lo antes posible.
					</div>
					<div class="form-feedback form-feedback-error" role="alert" hidden>
						<strong>No se pudo enviar.</strong> Revisa los datos o escríbeme por WhatsApp al
						<a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">{PHONE_DISPLAY}</a>.
					</div>
				</form>
			</section>
		</div>
	</section>
</Base>

<script>
	const form = document.getElementById("contact-form") as HTMLFormElement | null;
	if (form) {
		const submitBtn = form.querySelector<HTMLButtonElement>(".submit-btn");
		const successEl = form.querySelector<HTMLElement>(".form-feedback-success");
		const errorEl = form.querySelector<HTMLElement>(".form-feedback-error");

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			if (!submitBtn || !successEl || !errorEl) return;

			successEl.hidden = true;
			errorEl.hidden = true;

			if (!form.checkValidity()) {
				form.reportValidity();
				return;
			}

			submitBtn.disabled = true;
			form.classList.add("is-submitting");

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get("name") || ""),
				email: String(formData.get("email") || ""),
				company: String(formData.get("company") || ""),
				subject: String(formData.get("subject") || ""),
				message: String(formData.get("message") || ""),
				website: String(formData.get("website") || ""),
			};

			try {
				const response = await fetch("/api/contact", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				});

				if (!response.ok) {
					throw new Error(`HTTP ${response.status}`);
				}

				successEl.hidden = false;
				form.reset();
				successEl.scrollIntoView({ behavior: "smooth", block: "center" });
			} catch (err) {
				console.error("[contact-form]", err);
				errorEl.hidden = false;
				errorEl.scrollIntoView({ behavior: "smooth", block: "center" });
			} finally {
				submitBtn.disabled = false;
				form.classList.remove("is-submitting");
			}
		});
	}
</script>

<style>
	.contact-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* === 2-column grid === */
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		gap: var(--spacing-16);
		align-items: start;
	}

	/* === Left: contact info === */
	.contact-info {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
		position: sticky;
		top: calc(var(--nav-height) + var(--spacing-12));
	}

	.info-header {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.info-eyebrow {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.info-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0;
	}

	.contact-channels {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.channel {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: var(--spacing-4);
		padding: var(--spacing-4) var(--spacing-5);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition: all var(--transition-base);
	}

	.channel:hover {
		border-color: var(--color-accent);
		background: var(--color-bg-warm);
		transform: translateY(-1px);
	}

	.channel-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: 50%;
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.channel:hover .channel-icon {
		background: var(--color-accent);
		color: var(--color-on-accent);
		border-color: var(--color-accent);
	}

	.channel-body {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.channel-label {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		font-weight: 500;
		color: var(--color-text);
		letter-spacing: var(--tracking-snug);
	}

	.channel-value {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.channel-arrow {
		font-size: var(--font-size-base);
		color: var(--color-muted);
		transition: transform var(--transition-fast), color var(--transition-fast);
	}

	.channel:hover .channel-arrow {
		color: var(--color-accent);
		transform: translateX(3px);
	}

	.info-meta {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.meta-item {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.meta-label {
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.meta-value {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	/* === Right: form === */
	.contact-form-wrap {
		min-width: 0;
	}

	.form-header {
		margin-bottom: var(--spacing-8);
	}

	.form-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-3);
	}

	.form-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	.form-subtitle {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
		padding: var(--spacing-8);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.form-row {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
	}

	.form-row-double {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-5);
	}

	.form-field {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.form-field label {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
	}

	.required {
		color: var(--color-accent);
	}

	.form-field input,
	.form-field select,
	.form-field textarea {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-text);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: var(--spacing-3) var(--spacing-4);
		transition:
			border-color var(--transition-fast),
			box-shadow var(--transition-fast);
		width: 100%;
	}

	.form-field textarea {
		resize: vertical;
		min-height: 140px;
		line-height: var(--leading-relaxed);
	}

	.form-field input:focus,
	.form-field select:focus,
	.form-field textarea:focus {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px var(--color-accent-ring);
	}

	.form-field input::placeholder,
	.form-field textarea::placeholder {
		color: var(--color-muted);
	}

	.hp-field {
		position: absolute;
		left: -10000px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.form-privacy {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: var(--leading-relaxed);
		margin: 0;
	}

	.form-privacy a {
		color: var(--color-text-secondary);
		text-decoration: underline;
		text-decoration-color: var(--color-border);
		text-underline-offset: 3px;
	}

	.form-footer {
		display: flex;
		justify-content: flex-start;
		margin-top: var(--spacing-2);
	}

	.submit-btn {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-4) var(--spacing-8);
		background: var(--color-text);
		color: var(--color-bg);
		border: 1px solid var(--color-text);
		border-radius: 9999px;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 500;
		cursor: pointer;
		transition: all var(--transition-fast);
	}

	.submit-btn:hover:not(:disabled) {
		background: var(--color-accent);
		border-color: var(--color-accent);
	}

	.submit-btn:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.btn-loading {
		display: none;
	}

	.is-submitting .btn-label {
		display: none;
	}

	.is-submitting .btn-loading {
		display: inline;
	}

	.form-feedback {
		padding: var(--spacing-4) var(--spacing-5);
