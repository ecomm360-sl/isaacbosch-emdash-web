---
export const prerender = false;

import { Image } from "astro:assets";
import { getEmDashEntry, getSeoMeta, getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import SiteBlocks from "../components/SiteBlocks.astro";
import PressCard from "../components/PressCard.astro";
import AuthorityStrip from "../components/AuthorityStrip.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Credentials from "../components/Credentials.astro";
import type { BreadcrumbItem } from "../lib/seo";
import portraitSrc from "../assets/isaac-portrait.jpg";

const { entry, cacheHint } = await getEmDashEntry("pages", "sobre-isaac");

if (!entry) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const { entries: press } = await getEmDashCollection("press");
const seo = getSeoMeta(entry);

const breadcrumbs: BreadcrumbItem[] = [
	{ name: "Inicio", url: "/" },
	{ name: "Sobre Isaac", url: "/sobre-isaac" },
];
---

<Base
	title={seo.title ?? "Sobre Isaac Bosch — Consultor B2B y Fractional CIO"}
	description={seo.description ?? "Consultor eCommerce B2B y Fractional CIO en Barcelona. Fundador de eComm360, Integrafy y Approsearch."}
	image={seo.ogImage}
	content={{ collection: "pages", id: entry.data.id, slug: entry.id }}
	ogType="page"
	ogSlug="sobre-isaac"
	breadcrumbs={breadcrumbs}
>
	<article class="about-page">
		<!-- ====== HERO 2-COL ====== -->
		<header class="about-hero">
			<div class="hero-text">
				<Breadcrumbs items={breadcrumbs} />
				<span class="hero-eyebrow">Sobre mí</span>
				<h1 class="hero-title">{entry.data.title}</h1>
				<p class="hero-lead">
					Consultor eCommerce B2B, Fractional CIO y empresario desde los 20 años. Llevo la tecnología comercial a sectores que todavía venden como en 1998, desde Barcelona y para toda Europa.
				</p>
				<div class="hero-meta">
					<div class="hero-meta-item">
						<span class="hero-meta-label">Ubicación</span>
						<span class="hero-meta-value">Barcelona, España</span>
					</div>
					<div class="hero-meta-item">
						<span class="hero-meta-label">Activo desde</span>
						<span class="hero-meta-value">2009</span>
					</div>
					<div class="hero-meta-item">
						<span class="hero-meta-label">Roles</span>
						<span class="hero-meta-value">Consultor &middot; Fractional CIO &middot; Founder</span>
					</div>
				</div>
			</div>
			<div class="hero-portrait">
				<Image
					src={portraitSrc}
					alt="Retrato ilustrado de Isaac Bosch"
					width={960}
					height={960}
					loading="eager"
					decoding="async"
				/>
			</div>
		</header>

		<!-- ====== PROSE BODY (centered, narrow) ====== -->
		{entry.data.content && (
			<div class="about-body">
				<div class="prose">
					<SiteBlocks value={entry.data.content} />
				</div>
			</div>
		)}

		<!-- ====== CREDENTIALS (wide, 4 col) ====== -->
		<Credentials />
	</article>

	<AuthorityStrip />

	{press.length > 0 && (
		<section class="press-section">
			<div class="section-inner">
				<header class="section-header">
					<span class="section-eyebrow">Prensa</span>
					<h2 class="section-title">Apariciones en medios destacadas</h2>
					<p class="section-lead">
						Una selección de medios donde he hablado de eCommerce B2B, integración ERP y transformación digital industrial. <a href="/medios">Ver sala de prensa completa &rarr;</a>
					</p>
				</header>
				<div class="press-grid">
					{press.map((item) => <PressCard item={item} />)}
				</div>
			</div>
		</section>
	)}
</Base>

<style>
	.about-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-16);
	}

	/* ====== HERO ====== */
	.about-hero {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: var(--spacing-16);
		align-items: center;
		margin-bottom: var(--spacing-24);
		padding-bottom: var(--spacing-16);
		border-bottom: 1px solid var(--color-border);
	}

	.hero-text {
		min-width: 0;
	}

	.hero-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 4vw + 1rem, 4rem);
		font-weight: 500;
		line-height: 1.05;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.hero-lead {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-10);
		max-width: 38em;
	}

	.hero-meta {
		display: grid;
		grid-template-columns: repeat(3, auto);
		gap: var(--spacing-8);
		justify-content: start;
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.hero-meta-item {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.hero-meta-label {
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-muted);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.hero-meta-value {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
	}

	.hero-portrait {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-portrait img {
		width: 100%;
		max-width: 360px;
		height: auto;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		object-position: center 18%;
		border-radius: 50%;
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-lg);
	}

	/* ====== PROSE ====== */
	.about-body {
		max-width: 760px;
		margin: 0 auto var(--spacing-16);
	}

	.about-body :global(.prose) {
		max-width: none;
	}

	/* Decorate prose blockquotes more dramatically */
	.about-body :global(.prose blockquote) {
		font-family: var(--font-serif);
		font-size: clamp(1.5rem, 2vw + 0.75rem, 2rem);
		font-weight: 500;
		font-style: italic;
		line-height: 1.3;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		border-left: 3px solid var(--color-accent);
		padding: var(--spacing-2) 0 var(--spacing-2) var(--spacing-6);
		margin: var(--spacing-10) 0;
	}

	/* H2 in prose: add visual rhythm */
	.about-body :global(.prose h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: var(--spacing-12) 0 var(--spacing-4);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border);
		position: relative;
	}

	.about-body :global(.prose h2)::before {
		content: "";
		position: absolute;
		top: -1px;
		left: 0;
		width: 48px;
		height: 1px;
		background: var(--color-accent);
	}

	/* First H2 doesn't need top border */
	.about-body :global(.prose > h2:first-child),
	.about-body :global(.prose > p:first-child + h2) {
		border-top: none;
		padding-top: 0;
	}

	.about-body :global(.prose > h2:first-child)::before,
	.about-body :global(.prose > p:first-child + h2)::before {
		display: none;
	}

	.about-body :global(.prose p) {
		font-size: var(--font-size-base);
		line-height: var(--leading-prose);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-5);
	}

	.about-body :global(.prose strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	/* ====== Press section ====== */
	.press-section {
		padding: var(--spacing-20) var(--spacing-6);
		background: var(--color-bg);
		border-top: 1px solid var(--color-border);
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.section-header {
		max-width: 720px;
		margin-bottom: var(--spacing-10);
	}

	.section-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-3);
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.section-lead {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.section-lead a {
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
	}

	.section-lead a:hover {
		text-decoration: underline;
	}

	.press-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	/* ====== Responsive ====== */
	@media (max-width: 900px) {
		.about-hero {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
			text-align: left;
		}

		.hero-portrait img {
			max-width: 240px;
		}

		.hero-meta {
			grid-template-columns: 1fr 1fr;
			gap: var(--spacing-6);
		}
	}

	@media (max-width: 640px) {
		.about-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}

		.about-hero {
			gap: var(--spacing-8);
			margin-bottom: var(--spacing-16);
			padding-bottom: var(--spacing-12);
		}

		.hero-meta {
			grid-template-columns: 1fr;
			gap: var(--spacing-4);
		}

		.hero-portrait img {
			max-width: 180px;
		}

		.press-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
