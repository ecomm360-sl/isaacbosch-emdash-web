---
export const prerender = false;

import { getEmDashEntry, getSeoMeta } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import SiteBlocks from "../../components/SiteBlocks.astro";

const { slug } = Astro.params;
const result = await getEmDashEntry("projects", slug!);
if (!result) return Astro.redirect("/404");

const { entry: project, cacheHint } = result;
Astro.cache.set(cacheHint);

const seo = getSeoMeta(project);
---

<Base
	title={seo.title || project.data.title}
	description={seo.description || project.data.summary}
	image={seo.ogImage}
	robots={seo.robots}
	canonical={seo.canonical}
	type="website"
	content={{ collection: "projects", id: project.data.id, slug: project.id }}
>
	<article class="project-detail">
		{
			project.data.featured_image && (
				<div class="project-hero-image">
					<Image image={project.data.featured_image} />
				</div>
			)
		}

		<div class="project-content">
			<header class="project-header">
				<a href="/proyectos" class="back-link">&larr; Ecosistema</a>
				<span class="project-eyebrow">Proyecto</span>
				<h1 class="project-title">{project.data.title}</h1>
				{(project.data.client || project.data.year) && (
					<div class="project-meta">
						{project.data.client && (
							<span class="meta-item">
								<span class="meta-label">Rol:</span> {project.data.client}
							</span>
						)}
						{project.data.year && (
							<span class="meta-item">
								<span class="meta-label">Periodo:</span> {project.data.year}
							</span>
						)}
					</div>
				)}
				{project.data.summary && (
					<p class="project-summary">{project.data.summary}</p>
				)}
				{project.data.url && (
					<a
						href={project.data.url}
						target="_blank"
						rel="noopener noreferrer"
						class="project-link"
					>
						Visitar {project.data.url.replace(/^https?:\/\//, "").replace(/\/$/, "")} &rarr;
					</a>
				)}
			</header>

			{project.data.content && <SiteBlocks value={project.data.content} />}
		</div>
	</article>
</Base>

<style>
	.project-detail {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.project-hero-image {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		margin-bottom: var(--spacing-10);
	}

	.project-hero-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-content {
		max-width: var(--content-width);
		margin: 0 auto;
	}

	.project-header {
		margin-bottom: var(--spacing-12);
	}

	.back-link {
		display: inline-block;
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		margin-bottom: var(--spacing-8);
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.project-eyebrow {
		display: block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.project-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.project-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-6);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.meta-label {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.project-summary {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: 0 0 var(--spacing-6);
	}

	.project-link {
		display: inline-block;
		font-size: var(--font-size-base);
		font-weight: 500;
		color: var(--color-accent);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.project-link:hover {
		color: var(--color-accent-hover);
		text-decoration: underline;
	}
</style>
