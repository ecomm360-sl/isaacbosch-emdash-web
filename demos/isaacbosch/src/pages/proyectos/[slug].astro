---
export const prerender = false;

import { getEmDashEntry, getSeoMeta } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import SiteBlocks from "../../components/SiteBlocks.astro";

const { slug } = Astro.params;
const result = await getEmDashEntry("projects", slug!);
if (!result) return Astro.redirect("/404");

const { entry: project, cacheHint } = result;
Astro.cache.set(cacheHint);

const seo = getSeoMeta(project);
---

<Base
	title={seo.title || project.data.title}
	description={seo.description || project.data.summary}
	image={seo.ogImage}
	robots={seo.robots}
	canonical={seo.canonical}
	type="website"
	content={{ collection: "projects", id: project.data.id, slug: project.id }}
>
	<article class="project-detail">
		{
			project.data.featured_image && (
				<div class="project-hero-image">
					<Image image={project.data.featured_image} />
				</div>
			)
		}

		<div class="project-content">
			<header class="project-header">
				<h1 class="project-title">{project.data.title}</h1>
				{
					(project.data.client || project.data.year) && (
						<div class="project-meta">
							{project.data.client && (
								<span class="meta-item">
									<span class="meta-label">Cliente:</span>{" "}
									{project.data.client}
								</span>
							)}
							{project.data.year && (
								<span class="meta-item">
									<span class="meta-label">Ano:</span> {project.data.year}
								</span>
							)}
						</div>
					)
				}
				{
					project.data.summary && (
						<p class="project-summary">{project.data.summary}</p>
					)
				}
			</header>

			{project.data.content && <SiteBlocks value={project.data.content} />}
		</div>
	</article>
</Base>

<style>
	.project-detail {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.project-hero-image {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		margin-bottom: var(--spacing-8);
	}

	.project-hero-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-content {
		max-width: var(--content-width);
		margin: 0 auto;
	}

	.project-header {
		margin-bottom: var(--spacing-12);
	}

	.project-title {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin: 0 0 var(--spacing-4) 0;
	}

	.project-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-4);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.meta-label {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.project-summary {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: 0;
	}
</style>
