---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");

Astro.cache.set(cacheHint);
---

<Base
	title="Proyectos y ecosistema"
	description="El ecosistema de productos y empresas que he fundado: eComm360, Integrafy, Approsearch y Alabazweb. Proyectos que prueban lo que vendo."
>
	<section class="projects-page">
		<header class="page-header">
			<span class="page-eyebrow">Ecosistema</span>
			<h1 class="page-title">No solo asesoro: construyo</h1>
			<p class="page-subtitle">
				Ademas de la consultoria, fundo y opero productos propios para resolver los problemas que veo repetirse en cada proyecto B2B. Estos son los que estan vivos hoy.
			</p>
		</header>

		{projects.length === 0 ? (
			<p class="empty-message">
				Proximamente: casos de exito y proyectos destacados.
			</p>
		) : (
			<div class="projects-grid">
				{projects.map((project) => <ProjectCard project={project} />)}
			</div>
		)}
	</section>
</Base>

<style>
	.projects-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.empty-message {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	@media (max-width: 640px) {
		.projects-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
