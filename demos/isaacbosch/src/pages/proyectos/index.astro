---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { buildItemListSchema } from "../../lib/seo";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");

Astro.cache.set(cacheHint);

const TYPE_ORDER = ["Empresa", "Producto", "Tienda"] as const;
type ProjectType = (typeof TYPE_ORDER)[number];

const groups: Record<ProjectType, typeof projects> = {
	Empresa: [],
	Producto: [],
	Tienda: [],
};

for (const project of projects) {
	const type = (project.data.client ?? "Empresa") as ProjectType;
	if (type in groups) {
		groups[type].push(project);
	} else {
		groups.Empresa.push(project);
	}
}

const groupMeta: Record<ProjectType, { label: string; eyebrow: string; description: string }> = {
	Empresa: {
		eyebrow: "Empresas",
		label: "Empresas que he fundado",
		description: "El núcleo del Grupo eCommsistema. Donde diseño, ejecuto y opero todo lo demás.",
	},
	Producto: {
		eyebrow: "Productos",
		label: "Productos propios",
		description: "Software que construyo para resolver los problemas que veo repetirse en cada proyecto.",
	},
	Tienda: {
		eyebrow: "Tiendas",
		label: "Tiendas online propias",
		description: "Donde aplicamos en nuestra propia carne todo lo que vendemos. Cada tienda es un laboratorio en vivo.",
	},
};

const projectsListSchema = buildItemListSchema({
	name: "Mi ecosistema propio",
	items: projects.map((p) => ({
		name: p.data.title,
		url: `/proyectos/${p.id}`,
		description: p.data.summary ?? undefined,
	})),
});
---

<Base
	title="Mi ecosistema propio"
	description="eComm360, Integrafy, Approsearch y Alabazweb. Los productos y empresas que he fundado para resolver los problemas que veo repetirse en cada proyecto B2B industrial."
	ogType="page"
	ogSlug="proyectos"
	jsonLd={projectsListSchema}
>
	<section class="projects-page">
		<header class="page-header">
			<span class="page-eyebrow">Mi ecosistema propio</span>
			<h1 class="page-title">Empresas, productos y tiendas que he fundado</h1>
			<p class="page-subtitle">
				Además de consultar, construyo. El Grupo eCommsistema es mi laboratorio: tres empresas operativas, tres productos software propios y tres tiendas online donde aplicamos en carne propia todo lo que vendemos.
			</p>
		</header>

		{projects.length === 0 ? (
			<p class="empty-message">Próximamente.</p>
		) : (
			TYPE_ORDER.map((type) => {
				const items = groups[type];
				if (items.length === 0) return null;
				const meta = groupMeta[type];
				return (
					<div class="project-group">
						<header class="group-header">
							<span class="group-eyebrow">{meta.eyebrow}</span>
							<h2 class="group-title">{meta.label}</h2>
							<p class="group-description">{meta.description}</p>
						</header>
						<div class="projects-grid">
							{items.map((project) => <ProjectCard project={project} />)}
						</div>
					</div>
				);
			})
		)}

		<aside class="cross-link">
			<div class="cross-link-inner">
				<span class="cross-eyebrow">Clientes</span>
				<h2 class="cross-title">¿Has visto con quién he trabajado?</h2>
				<p class="cross-text">
					Más de 90 marcas en 12 sectores: Damm, Cofidis, Cetelem, Caixa, RACC, Vichy Catalán, Cirsa, Intersport, Brownie, PD Paola, Hoffmann, Kibuc, Madden y muchas más.
				</p>
				<a href="/clientes" class="cross-btn">Ver el muro de clientes &rarr;</a>
			</div>
		</aside>
	</section>
</Base>

<style>
	.projects-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.empty-message {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.project-group {
		margin-bottom: var(--spacing-20);
	}

	.project-group:last-of-type {
		margin-bottom: var(--spacing-12);
	}

	.group-header {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border);
	}

	.group-eyebrow {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.group-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0;
	}

	.group-description {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		max-width: 60ch;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);
	}

	.cross-link {
		margin-top: var(--spacing-12);
		padding: var(--spacing-12) var(--spacing-8);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.cross-link-inner {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
	}

	.cross-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-3);
	}

	.cross-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.cross-text {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-6);
	}

	.cross-btn {
		display: inline-flex;
		align-items: center;
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-text);
		color: var(--color-bg);
		border-radius: 9999px;
		font-weight: 500;
		text-decoration: none;
		transition: background var(--transition-fast);
	}

	.cross-btn:hover {
		background: var(--color-accent);
	}

	@media (max-width: 640px) {
		.projects-page {
			padding: var(--spacing-16) var(--spacing-5) var(--spacing-12);
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}

		.cross-link {
			padding: var(--spacing-8) var(--spacing-6);
		}
	}
</style>
