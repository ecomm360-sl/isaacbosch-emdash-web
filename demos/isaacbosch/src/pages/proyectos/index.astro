---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");

Astro.cache.set(cacheHint);
---

<Base
	title="Proyectos"
	description="Casos de exito en eCommerce B2B y automatizacion"
>
	<section class="projects-page">
		<header class="page-header">
			<h1 class="page-title">Proyectos</h1>
			<p class="page-subtitle">
				Casos de exito en eCommerce B2B y automatizacion
			</p>
		</header>

		{
			projects.length === 0 ? (
				<p class="empty-message">
					Proximamente: casos de exito y proyectos destacados.
				</p>
			) : (
				<div class="projects-grid">
					{projects.map((project) => (
						<ProjectCard project={project} />
					))}
				</div>
			)
		}
	</section>
</Base>

<style>
	.projects-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin: 0 0 var(--spacing-3) 0;
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.empty-message {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-8);
	}

	@media (max-width: 600px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
