---
export const prerender = false;

import { getEmDashEntry, getSeoMeta, getEntryTerms } from "emdash";
import { Image, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import SiteBlocks from "../../components/SiteBlocks.astro";
import TagList from "../../components/TagList.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import {
	buildArticleSchema,
	buildFaqPageSchema,
	type BreadcrumbItem,
	type FaqItem,
	type JsonLd,
} from "../../lib/seo";

const { slug } = Astro.params;

const { entry, cacheHint } = await getEmDashEntry("posts", slug!);

if (!entry) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const seo = getSeoMeta(entry);
const tags = await getEntryTerms("posts", entry.data.id, "tag");

const publishedDate = entry.data.publishedAt
	? entry.data.publishedAt.toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;

const publishedTime = entry.data.publishedAt
	? entry.data.publishedAt.toISOString()
	: null;

const modifiedTime = entry.data.updatedAt?.toISOString() ?? null;

const breadcrumbs: BreadcrumbItem[] = [
	{ name: "Inicio", url: "/" },
	{ name: "Blog", url: "/blog" },
	{ name: entry.data.title, url: `/blog/${entry.id}` },
];

// Extract FAQ items from any site.faq blocks in content
const faqItems: FaqItem[] = [];
if (Array.isArray(entry.data.content)) {
	for (const block of entry.data.content) {
		if (
			block &&
			typeof block === "object" &&
			(block as { _type?: string })._type === "site.faq"
		) {
			const items = (block as { items?: Array<{ question?: string; answer?: string }> }).items;
			if (Array.isArray(items)) {
				for (const it of items) {
					if (it?.question && it?.answer) {
						faqItems.push({ question: it.question, answer: it.answer });
					}
				}
			}
		}
	}
}

const articleSchema = buildArticleSchema({
	title: entry.data.title,
	description: entry.data.excerpt ?? "",
	url: `/blog/${entry.id}`,
	slug: entry.id,
	datePublished: publishedTime,
	dateModified: modifiedTime,
	image: entry.data.featured_image?.src ?? null,
	articleSection: tags.length > 0 ? tags[0].label : undefined,
});

const blogJsonLd: JsonLd[] = [articleSchema];
if (faqItems.length > 0) {
	blogJsonLd.push(buildFaqPageSchema(faqItems));
}
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	type="article"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	author="Isaac Bosch"
	content={{ collection: "posts", id: entry.data.id, slug: entry.id }}
	ogType="blog"
	ogSlug={entry.id}
	breadcrumbs={breadcrumbs}
	jsonLd={blogJsonLd}
	speakable={[".page-title", ".article-body p:first-of-type"]}
>
	<div class="article-layout">
		<article class="article-content">
			<header class="article-header">
				<Breadcrumbs items={breadcrumbs} />
				<h1 class="page-title">{entry.data.title}</h1>
				<div class="article-meta">
					<span class="meta-author">Isaac Bosch</span>
					{publishedDate && <span class="meta-sep">&middot;</span>}
					{publishedDate && <time class="article-date">{publishedDate}</time>}
				</div>
			</header>

			{
				entry.data.featured_image && (
					<div class="article-image">
						<Image image={entry.data.featured_image} />
					</div>
				)
			}

			<div class="article-body">
				{entry.data.content && <SiteBlocks value={entry.data.content} />}
			</div>

			{
				tags.length > 0 && (
					<footer class="article-footer">
						<TagList tags={tags.map((t) => ({ slug: t.slug, label: t.label }))} />
					</footer>
				)
			}
		</article>

		<aside class="article-sidebar">
			<WidgetArea name="sidebar" />
		</aside>
	</div>
</Base>

<style>
	.article-layout {
		display: grid;
		grid-template-columns: 1fr minmax(0, var(--content-width)) 280px 1fr;
		gap: var(--spacing-12);
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.article-content {
		grid-column: 2;
	}

	.article-sidebar {
		grid-column: 3;
		padding-top: var(--spacing-16);
	}

	.article-header {
		margin-bottom: var(--spacing-12);
	}

	.back-link {
		display: inline-block;
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		margin-bottom: var(--spacing-8);
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.article-header h1 {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.meta-author {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.meta-sep {
		color: var(--color-muted-light);
	}

	.article-image {
		margin-bottom: var(--spacing-8);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
	}

	.article-image :global(img) {
		width: 100%;
		height: auto;
	}

	.article-body {
		font-size: var(--font-size-lg);
		line-height: var(--leading-prose);
		color: var(--color-text-secondary);
	}

	.article-body :global(h2) {
		font-family: var(--font-serif);
		margin-top: var(--spacing-12);
		margin-bottom: var(--spacing-4);
		font-size: var(--font-size-2xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.2;
		color: var(--color-text);
	}

	.article-body :global(h3) {
		font-family: var(--font-serif);
		margin-top: var(--spacing-10);
		margin-bottom: var(--spacing-3);
		font-size: var(--font-size-xl);
		font-weight: 500;
		letter-spacing: var(--tracking-snug);
		color: var(--color-text);
	}

	.article-body :global(p) {
		margin-bottom: var(--spacing-5);
	}

	.article-body :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.article-body :global(ul),
	.article-body :global(ol) {
		margin-bottom: var(--spacing-4);
		padding-left: var(--spacing-6);
	}

	.article-body :global(li) {
		margin-bottom: var(--spacing-2);
	}

	.article-body :global(blockquote) {
		margin: var(--spacing-6) 0;
		padding-left: var(--spacing-4);
		border-left: 3px solid var(--color-accent);
		color: var(--color-text);
		font-style: italic;
	}

	.article-body :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.article-body :global(a:hover) {
		color: var(--color-accent-hover);
	}

	.article-footer {
		margin-top: var(--spacing-10);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	@media (max-width: 1024px) {
		.article-layout {
			grid-template-columns: 1fr;
			padding: var(--spacing-8) var(--spacing-4);
		}

		.article-content {
			grid-column: 1;
			max-width: var(--content-width);
			margin: 0 auto;
		}

		.article-sidebar {
			grid-column: 1;
			max-width: var(--content-width);
			margin: 0 auto;
			padding-top: var(--spacing-8);
			border-top: 1px solid var(--color-border-subtle);
		}
	}
</style>
