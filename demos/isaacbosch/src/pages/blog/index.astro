---
export const prerender = false;

import { getEmDashCollection, getTaxonomyTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 50,
});

Astro.cache.set(cacheHint);

const categories = await getTaxonomyTerms("category");
---

<Base title="Blog" description="Reflexiones sobre eCommerce B2B e IA Agentica">
	<div class="blog-page">
		<header class="page-header">
			<h1>Blog</h1>
			<p class="page-subtitle">Reflexiones sobre eCommerce B2B e IA Agentica</p>
		</header>

		{
			categories.length > 0 && (
				<nav class="category-filter">
					<a href="/blog" class="filter-link active">
						Todos
					</a>
					{categories.map((cat) => (
						<a href={`/blog/categoria/${cat.slug}`} class="filter-link">
							{cat.label}
						</a>
					))}
				</nav>
			)
		}

		{
			posts.length === 0 ? (
				<section class="empty-state">
					<p>No hay publicaciones todavia.</p>
				</section>
			) : (
				<div class="posts-grid">
					{posts.map((post) => (
						<PostCard post={post} />
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.blog-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.page-header {
		margin-bottom: var(--spacing-8);
	}

	.page-header h1 {
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
	}

	.page-subtitle {
		margin-top: var(--spacing-2);
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
	}

	.category-filter {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.filter-link {
		display: inline-block;
		padding: var(--spacing-1) var(--spacing-4);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
		text-decoration: none;
		transition:
			color var(--transition-fast),
			background var(--transition-fast);
	}

	.filter-link:hover {
		color: var(--color-text);
		background: var(--color-border);
	}

	.filter-link.active {
		color: var(--color-on-accent);
		background: var(--color-accent);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-20) 0;
		color: var(--color-muted);
	}

	@media (max-width: 900px) {
		.blog-page {
			padding: var(--spacing-8) var(--spacing-4);
		}

		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-8) var(--spacing-6);
		}
	}

	@media (max-width: 600px) {
		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}
</style>
