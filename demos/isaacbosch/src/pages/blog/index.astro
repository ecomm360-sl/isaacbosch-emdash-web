---
export const prerender = false;

import { getEmDashCollection, getTaxonomyTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { buildItemListSchema } from "../../lib/seo";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 50,
});

Astro.cache.set(cacheHint);

const categories = await getTaxonomyTerms("category");

const blogListSchema = buildItemListSchema({
	name: "Blog",
	description: "Notas sobre eCommerce B2B, IA y automatizacion",
	items: posts.slice(0, 20).map((p) => ({
		name: p.data.title,
		url: `/blog/${p.id}`,
		description: p.data.excerpt ?? undefined,
	})),
});
---

<Base
	title="Blog — eCommerce B2B, ERP e IA industrial"
	description="Artículos sobre eCommerce B2B, integración ERP, IA aplicada al negocio y transformación digital industrial."
	ogType="page"
	ogSlug="blog"
	jsonLd={blogListSchema}
>
	<div class="blog-page">
		<header class="page-header">
			<span class="page-eyebrow">Blog</span>
			<h1>Notas sobre eCommerce B2B, IA y automatización</h1>
			<p class="page-subtitle">
				Reflexiones dispersas sobre estrategia, tecnologia y la interseccion entre ambas. Sin calendario fijo, sin relleno.
			</p>
		</header>

		{categories.length > 0 && (
			<nav class="category-filter">
				<a href="/blog" class="filter-link active">Todos</a>
				{categories.map((cat) => (
					<a href={`/blog/categoria/${cat.slug}`} class="filter-link">{cat.label}</a>
				))}
			</nav>
		)}

		{posts.length === 0 ? (
			<section class="empty-state"><p>No hay publicaciones todavia.</p></section>
		) : (
			<div class="posts-grid">
				{posts.map((post) => <PostCard post={post} />)}
			</div>
		)}
	</div>
</Base>

<style>
	.blog-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6);
	}

	.page-header {
		max-width: 720px;
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.page-header h1 {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
		font-weight: 500;
		line-height: 1.1;
		letter-spacing: var(--tracking-tighter);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.category-filter {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-12);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.filter-link {
		display: inline-block;
		padding: var(--spacing-2) var(--spacing-4);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text-secondary);
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
		transition: all var(--transition-fast);
	}

	.filter-link:hover {
		color: var(--color-text);
		border-color: var(--color-text);
	}

	.filter-link.active {
		color: var(--color-on-accent);
		background: var(--color-accent);
		border-color: var(--color-accent);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-20) 0;
		color: var(--color-muted);
	}

	@media (max-width: 900px) {
		.blog-page {
			padding: var(--spacing-16) var(--spacing-5);
		}

		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-10) var(--spacing-6);
		}
	}

	@media (max-width: 600px) {
		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
		}
	}
</style>
