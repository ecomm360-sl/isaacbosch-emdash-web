---
import { getMenu } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import "../styles/theme.css";
import { SITE_NAME, TWITTER_HANDLE, SITE_URL } from "../data/site-meta";
import {
	buildOgImageUrl,
	buildOrganizationSchema,
	buildPersonSchema,
	buildProfessionalServiceSchema,
	buildBreadcrumbList,
	buildSpeakableSchema,
	getCanonicalUrl,
	type BreadcrumbItem,
	type JsonLd,
	type OgPageType,
} from "../lib/seo";

// Tracking IDs from public env vars (filled in Easypanel)
const GTM_ID = import.meta.env.PUBLIC_GTM_ID as string | undefined;
const GA4_ID = import.meta.env.PUBLIC_GA4_ID as string | undefined;
const LINKEDIN_PARTNER_ID = import.meta.env.PUBLIC_LINKEDIN_PARTNER_ID as
	| string
	| undefined;
const CLARITY_PROJECT_ID = import.meta.env.PUBLIC_CLARITY_PROJECT_ID as
	| string
	| undefined;
const CALENDLY_URL = import.meta.env.PUBLIC_CALENDLY_URL as string | undefined;

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	jsonLd?: JsonLd | JsonLd[];
	breadcrumbs?: BreadcrumbItem[];
	ogType?: OgPageType;
	ogSlug?: string;
	speakable?: string[];
}

const {
	title,
	description,
	image,
	canonical: canonicalProp,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	jsonLd,
	breadcrumbs,
	ogType,
	ogSlug,
	speakable,
} = Astro.props;

const siteTitle = SITE_NAME;
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const menu = await getMenu("primary");

// === Canonical: always explicit, normalized ===
const canonical = canonicalProp ?? getCanonicalUrl(Astro.url);

// === OG image: explicit > dynamic > fallback ===
let resolvedImage: string | null = image ?? null;
if (!resolvedImage && ogType && ogSlug) {
	resolvedImage = buildOgImageUrl({ type: ogType, slug: ogSlug });
}
if (!resolvedImage) {
	// Fallback to home OG (works for any page without explicit OG)
	resolvedImage = `${SITE_URL}/og/page/home.png`;
}

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image: resolvedImage,
	content,
	seo: { ogImage: resolvedImage, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;

// === Global JSON-LD: Organization + ProfessionalService + Person ===
// (WebSite schema is auto-emitted by EmDash core via EmDashHead — no need
// to duplicate it here.)
const globalSchemas: JsonLd[] = [
	buildOrganizationSchema(),
	buildProfessionalServiceSchema(),
	buildPersonSchema(),
];

if (breadcrumbs && breadcrumbs.length > 0) {
	globalSchemas.push(buildBreadcrumbList(breadcrumbs));
}

if (speakable && speakable.length > 0) {
	globalSchemas.push(buildSpeakableSchema(speakable));
}

// === Per-page extra JSON-LD passed via prop (supports single or array) ===
const extraSchemas: JsonLd[] = jsonLd
	? Array.isArray(jsonLd)
		? jsonLd
		: [jsonLd]
	: [];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		{GTM_ID && <link rel="preconnect" href="https://www.googletagmanager.com" />}
		{LINKEDIN_PARTNER_ID && <link rel="preconnect" href="https://snap.licdn.com" />}
		{CLARITY_PROJECT_ID && <link rel="preconnect" href="https://www.clarity.ms" />}
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="es" href={canonical} />
		<link rel="alternate" hreflang="x-default" href={canonical} />
		<meta name="twitter:site" content={TWITTER_HANDLE} />
		<meta name="twitter:creator" content={TWITTER_HANDLE} />
		<meta property="og:locale" content="es_ES" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		{globalSchemas.map((schema) => (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
		{extraSchemas.map((schema) => (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
		<script is:inline>
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
		{GTM_ID && (
			<script is:inline define:vars={{ GTM_ID }}>
				(function (w, d, s, l, i) {
					w[l] = w[l] || [];
					w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
					var f = d.getElementsByTagName(s)[0],
						j = d.createElement(s),
						dl = l != "dataLayer" ? "&l=" + l : "";
					j.async = true;
					j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
					f.parentNode.insertBefore(j, f);
				})(window, document, "script", "dataLayer", GTM_ID);
			</script>
		)}
		{GA4_ID && (
			<>
				<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
				<script is:inline define:vars={{ GA4_ID }}>
					window.dataLayer = window.dataLayer || [];
					function gtag() { dataLayer.push(arguments); }
					gtag("js", new Date());
					gtag("config", GA4_ID, { anonymize_ip: true });
				</script>
			</>
		)}
		{LINKEDIN_PARTNER_ID && (
			<script is:inline define:vars={{ LINKEDIN_PARTNER_ID }}>
				_linkedin_partner_id = LINKEDIN_PARTNER_ID;
				window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
				window._linkedin_data_partner_ids.push(_linkedin_partner_id);
				(function (l) {
					if (!l) {
						window.lintrk = function (a, b) { window.lintrk.q.push([a, b]); };
						window.lintrk.q = [];
					}
					var s = document.getElementsByTagName("script")[0];
					var b = document.createElement("script");
					b.type = "text/javascript"; b.async = true;
					b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
					s.parentNode.insertBefore(b, s);
				})(window.lintrk);
			</script>
		)}
		{CLARITY_PROJECT_ID && (
			<script is:inline define:vars={{ CLARITY_PROJECT_ID }}>
				(function (c, l, a, r, i, t, y) {
					c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
					t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
					y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
				})(window, document, "clarity", "script", CLARITY_PROJECT_ID);
			</script>
		)}
	</head>
	<body>
		<a href="#main-content" class="skip-to-content">Saltar al contenido principal</a>
		{GTM_ID && (
			<noscript>
				<iframe
					src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
					height="0"
					width="0"
					style="display:none;visibility:hidden"
					title="Google Tag Manager"
				></iframe>
			</noscript>
		)}
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header">
			<nav class="nav">
				<a href="/" class="site-title">{siteTitle}</a>
				<div class="nav-right">
					<div class="nav-links">
						{menu?.items.slice(0, 4).map((item) => (
							<a href={item.url} target={item.target}>{item.label}</a>
						))}
						{menu && menu.items.length > 4 && (
							<span class="nav-sep" aria-hidden="true"></span>
						)}
						{menu?.items.slice(4, -1).map((item) => (
							<a href={item.url} target={item.target}>{item.label}</a>
						))}
						{menu && menu.items.length > 0 && (
							<a
								href={menu.items[menu.items.length - 1].url}
								target={menu.items[menu.items.length - 1].target}
								class="nav-cta"
							>
								{menu.items[menu.items.length - 1].label}
							</a>
						)}
					</div>
					<button
						type="button"
						class="mobile-contact-trigger"
						aria-label="Abrir opciones de contacto"
						aria-expanded="false"
						data-overlay-trigger="contact"
					>
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
					</button>
					{isLoggedIn && (
						<a href="/_emdash/admin" class="nav-admin">Admin</a>
					)}
				</div>
			</nav>
		</header>

		<main id="main-content">
			<slot />
		</main>

		<button
			type="button"
			class="mobile-menu-trigger"
			aria-label="Abrir menu"
			aria-expanded="false"
			data-overlay-trigger="menu"
		>
			<svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
			<svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>

		<div class="mobile-overlay" id="overlay-menu" role="dialog" aria-modal="true" aria-label="Menu de navegacion" hidden>
			<nav class="overlay-menu">
				{menu?.items.slice(0, -1).map((item) => (
					<a href={item.url} class="overlay-menu-item">{item.label}</a>
				))}
				{menu && menu.items.length > 0 && (
					<>
						<span class="overlay-menu-divider" aria-hidden="true"></span>
						<a
							href={menu.items[menu.items.length - 1].url}
							class="overlay-menu-item overlay-menu-cta"
						>
							{menu.items[menu.items.length - 1].label}
						</a>
					</>
				)}
			</nav>
			<p class="overlay-tagline">
				<em>Del dato al pedido. Sin fricciones.</em>
			</p>
		</div>

		<div class="mobile-overlay" id="overlay-contact" role="dialog" aria-modal="true" aria-label="Opciones de contacto" hidden>
			<button
				type="button"
				class="overlay-close"
				aria-label="Cerrar opciones de contacto"
				data-overlay-close
			>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<div class="overlay-contact-inner">
				<header class="overlay-contact-header">
					<span class="overlay-eyebrow">Hablamos</span>
					<h2 class="overlay-title">Como prefieres contactar?</h2>
				</header>
				<div class="contact-options">
					<a href="/contacto" class="contact-option">
						<span class="contact-option-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						</span>
						<span class="contact-option-text">
							<span class="contact-option-title">Enviar mensaje</span>
							<span class="contact-option-desc">Formulario de contacto y mas datos</span>
						</span>
						<span class="contact-option-arrow" aria-hidden="true">→</span>
					</a>
					<a
						href="https://linkedin.com/in/isaacbosch"
						target="_blank"
						rel="noopener noreferrer"
						class="contact-option"
					>
						<span class="contact-option-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</span>
						<span class="contact-option-text">
							<span class="contact-option-title">LinkedIn</span>
							<span class="contact-option-desc">Conectemos en /in/isaacbosch</span>
						</span>
						<span class="contact-option-arrow" aria-hidden="true">→</span>
					</a>
					<a
						href="https://wa.me/34655588668?text=Hola%20Isaac%2C%20me%20gustaria%20hablar%20contigo"
						target="_blank"
						rel="noopener noreferrer"
						class="contact-option"
					>
						<span class="contact-option-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
						</span>
						<span class="contact-option-text">
							<span class="contact-option-title">WhatsApp</span>
							<span class="contact-option-desc">Respuesta rapida en horario laboral</span>
						</span>
						<span class="contact-option-arrow" aria-hidden="true">→</span>
					</a>
					<a href="tel:+34655588668" class="contact-option">
						<span class="contact-option-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						</span>
						<span class="contact-option-text">
							<span class="contact-option-title">Llamar</span>
							<span class="contact-option-desc">+34 655 588 668</span>
						</span>
						<span class="contact-option-arrow" aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</div>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href="/" class="footer-logo">{siteTitle}</a>
						<p class="footer-tagline">Consultor eCommerce B2B y Fractional CIO</p>
						<p class="footer-tagline-brand"><em>Del dato al pedido. Sin fricciones.</em></p>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">Servicios</h4>
						<ul class="footer-links">
							<li><a href="/servicios">Todos los servicios</a></li>
							<li><a href="/servicios/consultoria-ecommerce-b2b">Consultoria B2B</a></li>
							<li><a href="/fractional-cio">Fractional CIO</a></li>
							<li><a href="/proyectos">Mi ecosistema</a></li>
							<li><a href="/clientes">Clientes</a></li>
							<li><a href="/recursos">Recursos</a></li>
						</ul>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">Sobre</h4>
						<ul class="footer-links">
							<li><a href="/sobre-isaac">Sobre Isaac</a></li>
							<li><a href="/blog">Blog</a></li>
							<li><a href="/newsletter">Newsletter</a></li>
							<li><a href="/contacto">Contacto</a></li>
							<li><a href="https://linkedin.com/in/isaacbosch" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
							<li><a href="/rss.xml">RSS</a></li>
						</ul>
					</div>
					<div class="footer-widgets-section">
						<WidgetArea name="footer" />
					</div>
				</div>
				<div class="footer-bottom">
					<p class="footer-copyright">
						&copy; {new Date().getFullYear()} Isaac Bosch &middot; Hecho con intencion y cafe &middot; <a href="https://emdashcms.com">EmDash</a>
					</p>
					<div class="theme-switcher">
						<button type="button" class="theme-btn" data-theme="light" aria-label="Modo claro">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
						</button>
						<button type="button" class="theme-btn" data-theme="dark" aria-label="Modo oscuro">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
						</button>
						<button type="button" class="theme-btn" data-theme="system" aria-label="Tema del sistema">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
						</button>
					</div>
				</div>
			</div>
		</footer>

		<script>
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns = document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const root = document.documentElement;

			function setCookie(name: string, value: string, maxAge: number = 31536000) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (value === "") {
					document.cookie = `${name}=; path=/; max-age=0; SameSite=Lax${secure}`;
				} else {
					document.cookie = `${name}=${value}; path=/; max-age=${maxAge}; SameSite=Lax${secure}`;
				}
			}

			function setTheme(theme: string) {
				if (theme === "system") {
					setCookie("theme", "");
					root.classList.remove("light", "dark");
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						root.classList.add("dark");
					}
				} else {
					setCookie("theme", theme);
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "system";
			}

			const storedTheme = getStoredTheme();
			setTheme(storedTheme);
			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => setTheme(btn.dataset.theme || "system"));
			});
			window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
				if (getStoredTheme() === "system") root.classList.toggle("dark", e.matches);
			});

			// === Mobile overlays (menu + contact) ===
			const overlays = {
				menu: document.getElementById("overlay-menu"),
				contact: document.getElementById("overlay-contact"),
			} as const;
			const triggers = document.querySelectorAll<HTMLButtonElement>("[data-overlay-trigger]");
			const closers = document.querySelectorAll<HTMLButtonElement>("[data-overlay-close]");
			let activeOverlay: HTMLElement | null = null;
			let lastFocused: HTMLElement | null = null;

			function openOverlay(name: "menu" | "contact") {
				const overlay = overlays[name];
				if (!overlay) return;
				if (activeOverlay) closeOverlay();
				lastFocused = document.activeElement as HTMLElement;
				overlay.hidden = false;
				// Force reflow so the transition triggers
				void overlay.offsetWidth;
				overlay.classList.add("is-open");
				document.body.classList.add("no-scroll");
				if (name === "menu") {
					document.body.classList.add("menu-open");
				}
				activeOverlay = overlay;
				// Update aria-expanded on the matching trigger
				triggers.forEach((t) => {
					if (t.dataset.overlayTrigger === name) t.setAttribute("aria-expanded", "true");
				});
				// Focus first focusable element
				const focusable = overlay.querySelector<HTMLElement>("button, a, [tabindex]");
				focusable?.focus();
			}

			function closeOverlay() {
				if (!activeOverlay) return;
				const overlay = activeOverlay;
				overlay.classList.remove("is-open");
				document.body.classList.remove("no-scroll");
				document.body.classList.remove("menu-open");
				triggers.forEach((t) => t.setAttribute("aria-expanded", "false"));
				const handleEnd = () => {
					overlay.hidden = true;
					overlay.removeEventListener("transitionend", handleEnd);
				};
				overlay.addEventListener("transitionend", handleEnd);
				activeOverlay = null;
				lastFocused?.focus();
				lastFocused = null;
			}

			triggers.forEach((trigger) => {
				trigger.addEventListener("click", () => {
					const name = trigger.dataset.overlayTrigger as "menu" | "contact" | undefined;
					if (!name) return;
					// If this overlay is already active, close it (toggle behavior)
					if (activeOverlay === overlays[name]) {
						closeOverlay();
					} else {
						openOverlay(name);
					}
				});
			});

			closers.forEach((closer) => {
				closer.addEventListener("click", closeOverlay);
			});

			// Close when clicking on the overlay backdrop (not on inner content)
			Object.values(overlays).forEach((overlay) => {
				if (!overlay) return;
				overlay.addEventListener("click", (e) => {
					if (e.target === overlay) closeOverlay();
				});
			});

			// Escape key closes
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && activeOverlay) closeOverlay();
			});

			// Auto-close when navigating via menu links
			document.querySelectorAll<HTMLAnchorElement>(".overlay-menu-item").forEach((link) => {
				link.addEventListener("click", () => {
					// Let the navigation happen, then close (the page reload will handle cleanup)
					closeOverlay();
				});
			});
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
