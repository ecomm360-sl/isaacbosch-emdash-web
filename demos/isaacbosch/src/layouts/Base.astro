				color: #f5f4ed;
				text-decoration: none;
				transition: color var(--transition-fast), transform var(--transition-fast);
			}
			.overlay-menu-item:active,
			.overlay-menu-item:hover {
				color: #55C7DC;
				transform: translateX(4px);
			}
			.overlay-menu-divider {
				display: block;
