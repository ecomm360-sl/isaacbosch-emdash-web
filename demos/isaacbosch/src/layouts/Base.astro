			.mobile-contact-trigger:hover {
				background: var(--color-text);
				color: var(--color-bg);
				border-color: var(--color-text);
			}

			/* === Floating hamburger trigger (negativo, dark) === */
			.mobile-menu-trigger {
				display: none;
				position: fixed;
				bottom: max(24px, env(safe-area-inset-bottom, 24px));
				left: 50%;
				transform: translateX(-50%);
				width: 56px;
				height: 56px;
				align-items: center;
				justify-content: center;
				background: var(--color-text);
				border: 1px solid var(--color-text);
				border-radius: 50%;
				color: var(--color-bg);
				cursor: pointer;
				z-index: 250;
				box-shadow: var(--shadow-lg);
				transition: transform var(--transition-fast), background var(--transition-fast);
			}
			.mobile-menu-trigger:hover,
			.mobile-menu-trigger:active {
				transform: translateX(-50%) scale(1.05);
				background: var(--color-accent);
				border-color: var(--color-accent);
			}
			.mobile-menu-trigger .icon-close {
				display: none;
			}
			:global(body.menu-open) .mobile-menu-trigger .icon-menu {
				display: none;
			}
			:global(body.menu-open) .mobile-menu-trigger .icon-close {
				display: inline;
			}

			/* === Mobile overlays (full screen) === */
			.mobile-overlay {
				position: fixed;
				inset: 0;
				width: 100vw;
				height: 100vh;
				height: 100dvh;
				background: var(--color-bg);
				z-index: 200;
				opacity: 0;
				transform: translateY(20px);
				transition: opacity 220ms cubic-bezier(0.4, 0, 0.2, 1), transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
				overflow-y: auto;
				display: flex;
				flex-direction: column;
			}
			.mobile-overlay[hidden] {
				display: none;
			}
			.mobile-overlay.is-open {
				opacity: 1;
				transform: translateY(0);
			}
			.overlay-close {
				position: absolute;
				top: max(16px, env(safe-area-inset-top, 16px));
				right: 16px;
				width: 44px;
				height: 44px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: transparent;
				border: none;
				color: var(--color-text);
				cursor: pointer;
				border-radius: 50%;
				transition: background var(--transition-fast);
				z-index: 1;
			}
			.overlay-close:hover {
				background: var(--color-surface);
			}

			/* === Menu overlay (negativo, dark) === */
