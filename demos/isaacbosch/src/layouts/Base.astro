				.mobile-contact-trigger { display: inline-flex; }
				.mobile-menu-trigger { display: inline-flex; }
				main {
					margin-top: 0;
					padding-top: var(--spacing-6);
					padding-bottom: var(--spacing-24);
				}
				.footer-grid { grid-template-columns: 1fr 1fr; gap: var(--spacing-8); }
				.footer-brand { grid-column: span 2; max-width: none; }
				.footer-bottom { flex-direction: column; gap: var(--spacing-4); text-align: center; }
