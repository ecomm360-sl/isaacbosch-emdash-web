				color: var(--color-bg);
				border-radius: var(--radius-md);
				font-size: var(--font-size-sm);
				font-weight: 600;
				text-decoration: none;
				transition: top 0.2s ease;
			}
			.skip-to-content:focus {
				top: var(--spacing-4);
				outline: 2px solid var(--color-accent);
				outline-offset: 2px;
			}

			.site-header {
				position: sticky;
				top: var(--spacing-4);
				z-index: 100;
				margin: var(--spacing-4) auto 0;
				padding: 0 var(--spacing-4);
				max-width: var(--wide-width);
				width: calc(100% - var(--spacing-8));
			}
			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: var(--spacing-3) var(--spacing-6);
				height: var(--nav-height);
				background: color-mix(in srgb, var(--color-bg) 70%, transparent);
				backdrop-filter: blur(16px) saturate(180%);
				-webkit-backdrop-filter: blur(16px) saturate(180%);
				border: 1px solid var(--color-border);
				border-radius: 9999px;
				box-shadow: var(--shadow-md);
				transition: all var(--transition-base);
			}
			.site-title {
				font-family: var(--font-serif);
				font-size: var(--font-size-xl);
				font-weight: 500;
				color: var(--color-text);
				text-decoration: none;
				letter-spacing: var(--tracking-tight);
			}
			.site-title:hover { color: var(--color-accent); }
			.nav-right { display: flex; align-items: center; gap: var(--spacing-6); }
			.nav-links { display: flex; align-items: center; gap: var(--spacing-5); font-size: var(--font-size-sm); }
			.nav-links a { text-decoration: none; color: var(--color-text); transition: color var(--transition-fast); }
			.nav-links a:hover { color: var(--color-accent); }
			.nav-sep { display: inline-block; width: 1px; height: 18px; background: var(--color-border); margin: 0 var(--spacing-1); }
			.nav-cta {
				padding: var(--spacing-2) var(--spacing-4);
				background: var(--color-text);
				color: var(--color-bg) !important;
				border-radius: 9999px;
				font-weight: 500;
				transition: background var(--transition-fast), color var(--transition-fast);
			}
			.nav-cta:hover {
				background: var(--color-accent);
				color: var(--color-on-accent) !important;
