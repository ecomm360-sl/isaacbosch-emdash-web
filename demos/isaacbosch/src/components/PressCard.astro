---
interface Props {
	item: {
		data: {
			title: string;
			source?: string | null;
			date?: string | null;
			url?: string | null;
			summary?: string | null;
		};
	};
}

const { item } = Astro.props;
const isExternal = !!item.data.url && item.data.url !== "#";
const formattedDate = item.data.date
	? new Date(item.data.date).toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
		})
	: null;

const Tag = isExternal ? "a" : "div";
const tagProps = isExternal
	? { href: item.data.url, target: "_blank", rel: "noopener noreferrer" }
	: {};
---

<article class="press-card">
	<Tag class="card-link" {...tagProps}>
		<div class="card-meta">
			{item.data.source && <span class="card-source">{item.data.source}</span>}
			{formattedDate && <span class="card-date">{formattedDate}</span>}
		</div>
		<h3 class="card-title">
			{item.data.title}
			{isExternal && <span class="external-icon" aria-hidden="true">↗</span>}
		</h3>
		{item.data.summary && <p class="card-summary">{item.data.summary}</p>}
	</Tag>
</article>

<style>
	.press-card {
		border-radius: var(--radius);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		transition: all var(--transition-base);
	}

	.press-card:hover {
		border-color: var(--color-text);
	}

	.card-link {
		display: block;
		padding: var(--spacing-6);
		text-decoration: none;
		color: inherit;
	}

	a.card-link {
		cursor: pointer;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-3);
	}

	.card-source {
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.card-date {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.card-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 500;
		line-height: 1.3;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-2);
	}

	.external-icon {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-left: var(--spacing-1);
		display: inline-block;
		transition: transform var(--transition-fast);
	}

	a.card-link:hover .external-icon {
		transform: translate(2px, -2px);
		color: var(--color-accent);
	}

	.card-summary {
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
