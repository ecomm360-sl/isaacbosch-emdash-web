---
/**
 * Testimonials — sección de testimonios para home.
 *
 * Datos en src/data/testimonials.ts (placeholders pendientes de
 * confirmación con clientes reales).
 */
import { testimonials } from "../data/testimonials";
---

<section class="testimonials">
	<div class="testimonials-inner">
		<header class="section-header">
			<span class="section-eyebrow">Lo que dicen mis clientes</span>
			<h2 class="section-title">Resultados reales en empresas industriales</h2>
		</header>
		<div class="testimonials-grid">
			{testimonials.map((t) => (
				<figure class="testimonial">
					<blockquote class="testimonial-quote">
						<p>"{t.quote}"</p>
					</blockquote>
					<figcaption class="testimonial-author">
						{t.photo && (
							<img
								src={t.photo.src}
								alt={t.photo.alt}
								width="48"
								height="48"
								class="testimonial-photo"
								loading="lazy"
							/>
						)}
						<div class="testimonial-author-text">
							<span class="testimonial-name">{t.author}</span>
							<span class="testimonial-role">{t.role}</span>
							<span class="testimonial-company">{t.company}</span>
						</div>
					</figcaption>
				</figure>
			))}
		</div>
	</div>
</section>

<style>
	.testimonials {
		padding: var(--spacing-20) var(--spacing-6);
		background: var(--color-bg);
	}

	.testimonials-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.section-header {
		max-width: 720px;
		margin-bottom: var(--spacing-12);
	}

	.section-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-3);
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}

	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}

	.testimonial {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: var(--spacing-6);
		padding: var(--spacing-8);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		margin: 0;
		transition: all var(--transition-base);
	}

	.testimonial:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.testimonial-quote {
		margin: 0;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-style: italic;
		line-height: 1.5;
		color: var(--color-text);
	}

	.testimonial-quote p {
		margin: 0;
	}

	.testimonial-author {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.testimonial-photo {
		width: 48px;
		height: 48px;
		object-fit: cover;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.testimonial-author-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.testimonial-name {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-text);
	}

	.testimonial-role {
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
	}

	.testimonial-company {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	@media (max-width: 1024px) {
		.testimonials-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.testimonials {
			padding: var(--spacing-16) var(--spacing-5);
		}
		.testimonial {
			padding: var(--spacing-6);
		}
	}
</style>
