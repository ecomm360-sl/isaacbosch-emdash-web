	horizons: { bg: "#ed1c24", fg: "#ffffff", initials: "NH" },
	maxpho: { bg: "#f7941d", fg: "#ffffff", initials: "M" },
};
---

<section class="credentials">
	<header class="credentials-header">
		<span class="credentials-eyebrow">Credenciales</span>
		<h2 class="credentials-title">Formacion certificada</h2>
		<p class="credentials-lead">
			Mas de 20 acreditaciones profesionales en IA, ventas, liderazgo, metodologia, gestion comercial y normativa digital.
		</p>
	</header>

	{groups.map((group) => (
		<div class="cred-group">
			<h3 class="group-title">{group.title}</h3>
			<div class="cred-grid">
				{group.credentials.map((c) => {
					const style = issuerStyles[c.issuerKey];
					return (
						<article class="cred-card">
							<div class="cred-top">
								{c.issuerKey === "google" ? (
									<img
										src="https://www.google.com/favicon.ico"
										alt="Google"
										width="32"
										height="32"
										class="cred-logo cred-logo-google"
										loading="lazy"
									/>
								) : (
									<div
										class="cred-logo cred-logo-svg"
										style={`background:${style.bg};color:${style.fg};`}
										aria-label={c.issuer}
									>
										{style.initials}
									</div>
								)}
								{c.featured && (
									<span class="cred-badge">Especializacion</span>
								)}
							</div>
							<h4 class="cred-name">{c.name}</h4>
							<p class="cred-issuer">{c.issuer}</p>
							<div class="cred-meta">
								<time class="cred-date">{c.date}</time>
								{c.id && (
									<>
										<span class="cred-sep" aria-hidden="true">·</span>
										<code class="cred-id">ID: {c.id}</code>
									</>
								)}
							</div>
						</article>
					);
				})}
			</div>
		</div>
	))}
</section>

<style>
	.credentials {
		max-width: var(--wide-width);
		margin: var(--spacing-16) auto 0;
		padding: var(--spacing-16) 0 0;
		border-top: 1px solid var(--color-border);
	}

	.credentials-header {
		margin-bottom: var(--spacing-12);
	}

	.credentials-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: #1B5585;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.credentials-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	.credentials-lead {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		max-width: 60ch;
	}

	/* === Group === */
	.cred-group {
		margin-bottom: var(--spacing-12);
	}

	.cred-group:last-of-type {
		margin-bottom: 0;
	}

	.group-title {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
		padding-bottom: var(--spacing-2);
		border-bottom: 2px solid #55C7DC;
	}

	/* === Grid (4 cols desktop, 3 tablet, 2 small tablet, 1 mobile) === */
	.cred-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-4);
	}

	@media (max-width: 1024px) {
		.cred-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 800px) {
		.cred-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* === Card === */
	.cred-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
		padding: var(--spacing-5);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		box-shadow: 0 1px 3px rgba(20, 20, 19, 0.04);
		transition: all var(--transition-base);
	}

	.cred-card:hover {
		border-color: #1B5585;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(20, 20, 19, 0.08);
	}

	.cred-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-1);
	}

	/* === Logo === */
	.cred-logo {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 6px;
		flex-shrink: 0;
	}

	.cred-logo-google {
		background: #f3f4f6;
		padding: 6px;
		object-fit: contain;
	}

	.cred-logo-svg {
		font-family: var(--font-sans);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	/* === Badge === */
	.cred-badge {
		display: inline-block;
		padding: 3px 10px;
		background: #55C7DC;
		color: #0f2f3a;
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-radius: 999px;
		white-space: nowrap;
	}

	/* === Card content === */
	.cred-name {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		line-height: 1.3;
		color: var(--color-text);
		margin: var(--spacing-2) 0 0;
	}

	.cred-issuer {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.4;
	}

	.cred-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		margin-top: var(--spacing-2);
		padding-top: var(--spacing-2);
		border-top: 1px solid var(--color-border-subtle);
	}

	.cred-sep {
		color: var(--color-border);
	}

	.cred-id {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
		background: var(--color-bg-warm);
		padding: 1px 6px;
		border-radius: 3px;
	}

	@media (max-width: 480px) {
		.credentials {
			padding: var(--spacing-12) 0 0;
			margin-top: var(--spacing-12);
		}

		.cred-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-3);
		}
	}
</style>
