	palantir: { bg: "#000000", fg: "#ffffff", initials: "P" },
	scrum: { bg: "#ff6b35", fg: "#ffffff", initials: "SM" },
	adwords: { bg: "#4285f4", fg: "#ffffff", initials: "Ad" },
	ua: { bg: "#003366", fg: "#ffffff", initials: "UA" },
	unimooc: { bg: "#22c55e", fg: "#ffffff", initials: "U" },
	dale: { bg: "#c41e3a", fg: "#ffffff", initials: "DC" },
	ybi: { bg: "#f59e0b", fg: "#ffffff", initials: "YBI" },
	goma: { bg: "#7c4a1e", fg: "#ffffff", initials: "IG" },
