---
import { authority } from "../data/authority";
---

<section class="ecosystem">
	<div class="ecosystem-inner">
		<header class="ecosystem-header">
			<span class="ecosystem-eyebrow">Ecosistema</span>
			<h2 class="ecosystem-title">El laboratorio donde nacen las soluciones</h2>
			<p class="ecosystem-subtitle">
				No solo asesoro: construyo. Estos son los proyectos que he fundado y opero.
			</p>
		</header>
		<div class="products">
			{authority.ecosystemProducts.map((product) => (
				<a
					href={product.url || "/proyectos/"}
					class="product"
					target={product.url ? "_blank" : undefined}
					rel={product.url ? "noopener noreferrer" : undefined}
				>
					<div class="product-header">
						<h3 class="product-name">{product.name}</h3>
						<span class="product-year">{product.year}</span>
					</div>
					<p class="product-tagline">{product.tagline}</p>
					{product.url && <span class="product-link">Visitar &rarr;</span>}
				</a>
			))}
		</div>
		<a href="/proyectos/" class="ecosystem-cta">
			Ver el ecosistema completo &rarr;
		</a>
	</div>
</section>

<style>
	.ecosystem {
		padding: var(--spacing-24) var(--spacing-6);
		background: var(--color-bg);
	}

	.ecosystem-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.ecosystem-header {
		max-width: 640px;
		margin-bottom: var(--spacing-12);
	}

	.ecosystem-eyebrow {
		display: inline-block;
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-4);
	}

	.ecosystem-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		line-height: 1.15;
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	.ecosystem-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: 0;
	}

	.products {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-8);
	}

	.product {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		padding: var(--spacing-6);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition: all var(--transition-base);
	}

	.product:hover {
		border-color: var(--color-accent);
		background: var(--color-bg);
	}

	.product-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}

	.product-name {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}

	.product:hover .product-name {
		color: var(--color-accent);
	}

	.product-year {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.product-tagline {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		flex-grow: 1;
	}

	.product-link {
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-accent);
		margin-top: var(--spacing-2);
	}

	.ecosystem-cta {
		display: inline-block;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.ecosystem-cta:hover {
		color: var(--color-accent);
	}

	@media (max-width: 900px) {
		.products {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.products {
			grid-template-columns: 1fr;
		}
	}
</style>
