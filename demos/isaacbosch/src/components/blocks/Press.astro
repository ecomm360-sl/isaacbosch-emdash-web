---
interface Props {
	node: {
		headline?: string;
		items: Array<{
			title: string;
			source: string;
			date?: string;
			url?: string;
		}>;
	};
}

const { node } = Astro.props;
const { headline, items } = node;
---

<section class="press">
	{headline && <h2 class="press-headline">{headline}</h2>}
	<div class="press-grid">
		{items.map((item) => {
			const Tag = item.url ? "a" : "div";
			const linkProps = item.url ? { href: item.url, target: "_blank", rel: "noopener noreferrer" } : {};
			return (
				<Tag class:list={["press-card", { "press-card-link": !!item.url }]} {...linkProps}>
					<p class="press-title">{item.title}</p>
					<div class="press-meta">
						<span class="press-source">{item.source}</span>
						{item.date && <span class="press-date">{item.date}</span>}
					</div>
				</Tag>
			);
		})}
	</div>
</section>

<style>
	.press {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--spacing-3xl) var(--spacing-lg);
	}

	.press-headline {
		font-size: var(--font-size-2xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-xl);
	}

	.press-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-md);
	}

	.press-card {
		background: var(--color-surface);
		border-radius: var(--radius);
		padding: var(--spacing-lg);
		text-decoration: none;
		color: inherit;
	}

	.press-card-link {
		transition: opacity 0.15s ease;
	}

	.press-card-link:hover {
		opacity: 0.8;
	}

	.press-title {
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-text);
		margin: 0 0 var(--spacing-sm);
		line-height: var(--leading-snug);
	}

	.press-meta {
		display: flex;
		gap: var(--spacing-sm);
		align-items: center;
		font-size: var(--font-size-xs);
	}

	.press-source {
		color: var(--color-muted);
	}

	.press-date {
		color: var(--color-muted);
	}

	.press-date::before {
		content: "\00b7";
		margin-right: var(--spacing-sm);
	}

	@media (max-width: 640px) {
		.press-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
