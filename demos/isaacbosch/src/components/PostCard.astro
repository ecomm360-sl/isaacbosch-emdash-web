---
import { Image } from "emdash/ui";

interface Props {
	post: {
		id: string;
		data: {
			title: string;
			excerpt?: string | null;
			featured_image?: { id: string; src?: string; alt?: string } | null;
		};
	};
}

const { post } = Astro.props;
---

<article class="post-card">
	{
		post.data.featured_image && (
			<a href={`/blog/${post.id}`} class="card-image">
				<Image image={post.data.featured_image} />
			</a>
		)
	}
	<div class="card-body">
		<h3 class="card-title">
			<a href={`/blog/${post.id}`}>{post.data.title}</a>
		</h3>
		{post.data.excerpt && <p class="card-excerpt">{post.data.excerpt}</p>}
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.card-image {
		display: block;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--color-surface);
	}

	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.2s ease;
	}

	.card-image:hover :global(img) {
		transform: scale(1.02);
	}

	.card-body {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.card-title {
		font-size: var(--font-size-lg);
		font-weight: 600;
		line-height: 1.3;
		margin: 0;
	}

	.card-title a {
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.card-title a:hover {
		color: var(--color-accent);
	}

	.card-excerpt {
		font-size: var(--font-size-base);
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
