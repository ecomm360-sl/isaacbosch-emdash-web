---
import { Image } from "emdash/ui";

interface Props {
	post: {
		id: string;
		data: {
			title: string;
			excerpt?: string | null;
			featured_image?: { id: string; src?: string; alt?: string } | null;
			publishedAt?: Date | null;
		};
	};
}

const { post } = Astro.props;

const formattedDate = post.data.publishedAt
	? post.data.publishedAt.toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;
---

<article class="post-card">
	{post.data.featured_image && (
		<a href={`/blog/${post.id}`} class="card-image">
			<Image image={post.data.featured_image} />
		</a>
	)}
	<div class="card-body">
		{formattedDate && <time class="card-date">{formattedDate}</time>}
		<h3 class="card-title">
			<a href={`/blog/${post.id}`}>{post.data.title}</a>
		</h3>
		{post.data.excerpt && <p class="card-excerpt">{post.data.excerpt}</p>}
		<a href={`/blog/${post.id}`} class="card-readmore">Leer articulo &rarr;</a>
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
	}

	.card-image {
		display: block;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--color-surface);
	}

	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition-slow);
	}

	.card-image:hover :global(img) {
		transform: scale(1.04);
	}

	.card-body {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.card-date {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		font-weight: 500;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.card-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: var(--tracking-tight);
		margin: 0;
	}

	.card-title a {
		color: var(--color-text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.card-title a:hover {
		color: var(--color-accent);
	}

	.card-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-readmore {
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
		margin-top: var(--spacing-1);
		transition: gap var(--transition-fast);
	}

	.card-readmore:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
</style>
