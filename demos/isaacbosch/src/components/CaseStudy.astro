---
/**
 * CaseStudy — bloque reutilizable de caso de éxito.
 *
 * Pasar el slug del servicio para cargar el caso correspondiente desde
 * src/data/case-studies.ts. Datos placeholder pendientes de validación.
 */
import { caseStudies } from "../data/case-studies";

interface Props {
	slug: keyof typeof caseStudies | string;
}

const { slug } = Astro.props;
const caseData = caseStudies[slug as keyof typeof caseStudies];
---

{caseData && (
	<aside class="case-study">
		<header class="case-header">
			<span class="case-eyebrow">Caso real</span>
			<p class="case-meta">{caseData.sector} · {caseData.companySize}</p>
		</header>

		<div class="case-grid">
			<div class="case-step">
				<span class="case-step-label">Situación</span>
				<p class="case-step-text">{caseData.situation}</p>
			</div>
			<div class="case-step">
				<span class="case-step-label">Intervención</span>
				<p class="case-step-text">{caseData.intervention}</p>
			</div>
			<div class="case-step">
				<span class="case-step-label">Resultado</span>
				<p class="case-step-text">{caseData.result}</p>
			</div>
		</div>

		<footer class="case-footer">
			<span class="case-metric">{caseData.metric}</span>
		</footer>
	</aside>
)}

<style>
	.case-study {
		max-width: 760px;
		margin: var(--spacing-16) auto;
		padding: var(--spacing-10);
		background: var(--color-bg-warm);
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent);
		border-radius: var(--radius-lg);
	}

	.case-header {
		margin-bottom: var(--spacing-8);
	}

	.case-eyebrow {
		display: inline-block;
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-accent);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		margin-bottom: var(--spacing-2);
	}

	.case-meta {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin: 0;
	}

	.case-grid {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
		margin-bottom: var(--spacing-8);
	}

	.case-step {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.case-step-label {
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-text);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.case-step-text {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.case-footer {
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
		text-align: center;
	}

	.case-metric {
		display: inline-block;
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 500;
		font-style: italic;
		color: var(--color-text);
		line-height: 1.3;
	}

	@media (max-width: 640px) {
		.case-study {
			padding: var(--spacing-6);
			margin: var(--spacing-12) auto;
		}
		.case-metric {
			font-size: var(--font-size-lg);
		}
	}
</style>
