---
import type { Client } from "../data/clients";
import { CLIENT_SECTORS } from "../data/clients";

interface Props {
	client: Client;
}

const { client } = Astro.props;
const sectorLabel = CLIENT_SECTORS[client.sector];
const tooltip = `${sectorLabel} · ${client.projectType}`;

const Tag = client.url ? "a" : "div";
const tagProps = client.url
	? { href: client.url, target: "_blank", rel: "noopener noreferrer" }
	: {};
---

<Tag class="client-card" data-sector={client.sector} title={tooltip} {...tagProps}>
	<div class="client-logo-wrap">
		<img
			src={client.logo}
			alt={`${client.name} logo`}
			class="client-logo"
			loading="lazy"
			decoding="async"
		/>
	</div>
	<span class="client-name">{client.name}</span>
</Tag>

<style>
	.client-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-2);
		padding: var(--spacing-5) var(--spacing-4);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition: all var(--transition-base);
		aspect-ratio: 16 / 11;
		overflow: hidden;
	}

	a.client-card {
		cursor: pointer;
	}

	.client-card:hover {
		border-color: var(--color-accent);
		background: var(--color-bg);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.client-logo-wrap {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-height: 60px;
	}

	.client-logo {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain;
		filter: grayscale(100%) contrast(0.9);
		opacity: 0.68;
		mix-blend-mode: multiply;
		transition:
			filter var(--transition-base),
			opacity var(--transition-base),
			transform var(--transition-base);
	}

	.client-card:hover .client-logo {
		filter: none;
		opacity: 1;
		transform: scale(1.05);
	}

	.client-name {
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-muted);
		text-align: center;
		opacity: 0;
		transition: opacity var(--transition-base);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		line-height: 1;
	}

	.client-card:hover .client-name {
		opacity: 1;
		color: var(--color-text-secondary);
	}
</style>
