# Resend API integration for the /contacto form
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address. Must be a verified domain in your Resend account.
# For testing, you can use the default Resend onboarding sender:
#   RESEND_FROM=Isaac Bosch <onboarding@resend.dev>
# For production, verify isaacbosch.com in Resend and use:
#   RESEND_FROM=Isaac Bosch <hola@isaacbosch.com>
RESEND_FROM=Isaac Bosch <onboarding@resend.dev>

# Where contact form submissions are delivered.
CONTACT_EMAIL_TO=hola@isaacbosch.com
